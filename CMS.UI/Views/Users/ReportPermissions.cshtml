@using CMS.UI.Controllers
@model UserReportPermissionsViewModel
@{
    ViewData["Title"] = $"Permisos de Reportes - {Model.UserName}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        .permission-card {
            background: linear-gradient(135deg, #1a1f36 0%, #252b47 100%);
            border: 1px solid rgba(6, 182, 212, 0.3);
            transition: all 0.3s ease;
        }
        
        .permission-card:hover {
            border-color: rgba(6, 182, 212, 0.6);
            transform: translateY(-2px);
        }
        
        .permission-card.allowed {
            border-left: 4px solid #22c55e;
        }
        
        .permission-card.denied {
            border-left: 4px solid #ef4444;
            opacity: 0.7;
        }
        
        .permission-card.neutral {
            border-left: 4px solid #64748b;
            opacity: 0.7;
        }
        
        .category-header {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            border: 1px solid rgba(6, 182, 212, 0.2);
        }
        
        .report-icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            font-size: 1.2rem;
        }
        
        .report-icon.allowed {
            background: rgba(34, 197, 94, 0.2);
            color: #22c55e;
        }
        
        .report-icon.denied {
            background: rgba(239, 68, 68, 0.2);
            color: #ef4444;
        }
        
        .report-icon.neutral {
            background: rgba(100, 116, 139, 0.2);
            color: #64748b;
        }
        
        .btn-grant {
            background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
            border: none;
        }
        
        .btn-grant:hover {
            background: linear-gradient(135deg, #15803d 0%, #16a34a 100%);
        }
        
        .btn-revoke {
            background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%);
            border: none;
        }
        
        .btn-revoke:hover {
            background: linear-gradient(135deg, #b91c1c 0%, #dc2626 100%);
        }
        
        .stats-card {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            border: 1px solid rgba(6, 182, 212, 0.3);
        }
    </style>
}

<div class="container-fluid py-4">
    <!-- Breadcrumb y Header -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-info text-decoration-none">Usuarios</a></li>
                    <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.UserId" class="text-info text-decoration-none">@Model.UserName</a></li>
                    <li class="breadcrumb-item"><a asp-action="CompanyAuth" asp-route-userId="@Model.UserId" asp-route-companyId="@Model.CompanyId" class="text-info text-decoration-none">Autorización</a></li>
                    <li class="breadcrumb-item active text-muted">Reportes</li>
                </ol>
            </nav>
            <h2 class="text-white mb-1">
                <i class="bi bi-bar-chart me-2 text-info"></i>Permisos de Reportes
            </h2>
            <p class="text-muted mb-0">
                <i class="bi bi-person me-1"></i>@Model.UserName
                <span class="mx-2">•</span>
                <i class="bi bi-building me-1"></i>@Model.CompanyName
            </p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="CompanyAuth" asp-route-userId="@Model.UserId" asp-route-companyId="@Model.CompanyId" 
               class="btn btn-outline-info">
                <i class="bi bi-shield-lock me-2"></i>Ver Permisos
            </a>
            <a asp-action="Details" asp-route-id="@Model.UserId" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Volver
            </a>
        </div>
    </div>

    <!-- Estadísticas -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stats-card rounded p-3 text-center">
                <div class="display-6 text-success fw-bold">@Model.ReportPermissions.Count(r => r.IsAllowed)</div>
                <div class="text-muted small">Reportes Permitidos</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card rounded p-3 text-center">
                <div class="display-6 text-danger fw-bold">@Model.ReportPermissions.Count(r => r.IsDenied)</div>
                <div class="text-muted small">Reportes Denegados</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stats-card rounded p-3 text-center">
                <div class="display-6 text-secondary fw-bold">@Model.ReportPermissions.Count(r => !r.IsAllowed && !r.IsDenied)</div>
                <div class="text-muted small">Sin Asignar</div>
            </div>
        </div>
    </div>

    <!-- Alertas -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Lista de Reportes agrupados por Categoría -->
    @{
        var reportsByCategory = Model.ReportPermissions
            .GroupBy(r => new { r.CategoryId, r.CategoryName })
            .OrderBy(g => g.Key.CategoryName);
    }

    @foreach (var category in reportsByCategory)
    {
        <div class="mb-4">
            <!-- Header de Categoría -->
            <div class="category-header rounded-top p-3 d-flex align-items-center justify-content-between">
                <h5 class="text-white mb-0">
                    <i class="bi bi-folder me-2 text-info"></i>@category.Key.CategoryName
                </h5>
                <span class="badge bg-info">@category.Count() reportes</span>
            </div>

            <!-- Reportes de la Categoría -->
            <div class="row g-3 mt-0">
                @foreach (var report in category.OrderBy(r => r.ReportName))
                {
                    var statusClass = report.IsAllowed ? "allowed" : (report.IsDenied ? "denied" : "neutral");
                    var iconClass = report.IsAllowed ? "allowed" : (report.IsDenied ? "denied" : "neutral");
                    
                    <div class="col-md-6 col-lg-4">
                        <div class="permission-card @statusClass rounded p-3 h-100">
                            <div class="d-flex align-items-start">
                                <div class="report-icon @iconClass me-3">
                                    <i class="bi @(report.Icon ?? "bi-file-earmark-bar-graph")"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="text-white mb-1">@report.ReportName</h6>
                                    <p class="text-muted small mb-2 text-truncate" title="@report.Description">
                                        @(report.Description ?? "Sin descripción")
                                    </p>
                                    <div class="d-flex gap-2">
                                        @if (report.IsAllowed)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i>Permitido
                                            </span>
                                            <form asp-action="RevokeReportAccess" method="post" class="d-inline">
                                                <input type="hidden" name="userId" value="@Model.UserId" />
                                                <input type="hidden" name="companyId" value="@Model.CompanyId" />
                                                <input type="hidden" name="reportId" value="@report.ReportId" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" 
                                                        onclick="return confirm('¿Está seguro de revocar el acceso a este reporte?');">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        else if (report.IsDenied)
                                        {
                                            <span class="badge bg-danger">
                                                <i class="bi bi-x-circle me-1"></i>Denegado
                                            </span>
                                            <form asp-action="GrantReportAccess" method="post" class="d-inline">
                                                <input type="hidden" name="userId" value="@Model.UserId" />
                                                <input type="hidden" name="companyId" value="@Model.CompanyId" />
                                                <input type="hidden" name="reportId" value="@report.ReportId" />
                                                <button type="submit" class="btn btn-sm btn-grant text-white">
                                                    <i class="bi bi-check-circle me-1"></i>Permitir
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-dash-circle me-1"></i>Sin asignar
                                            </span>
                                            <form asp-action="GrantReportAccess" method="post" class="d-inline">
                                                <input type="hidden" name="userId" value="@Model.UserId" />
                                                <input type="hidden" name="companyId" value="@Model.CompanyId" />
                                                <input type="hidden" name="reportId" value="@report.ReportId" />
                                                <button type="submit" class="btn btn-sm btn-grant text-white">
                                                    <i class="bi bi-check-circle me-1"></i>Permitir
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (!Model.ReportPermissions.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bar-chart display-1 text-muted mb-3"></i>
            <h5 class="text-white">No hay reportes configurados</h5>
            <p class="text-muted">No se encontraron reportes en el sistema.</p>
        </div>
    }
</div>
