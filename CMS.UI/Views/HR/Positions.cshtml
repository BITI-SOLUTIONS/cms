@* ================================================================================
   VISTA: CMS.UI/Views/HR/Positions.cshtml
   PROPOSITO: Mantenimiento de puestos/cargos - Modulo Human Resources
   AUTOR: EAMR, BITI SOLUTIONS S.A
   CREADO: 2026-07-05
   ================================================================================ *@
@{
    ViewData["Title"] = "Puestos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    small, .form-text, small.text-muted, .text-muted small { color: #cbd5e1 !important; }
    .level-badge {
        font-size: .65rem; font-weight: 700; text-transform: uppercase;
        padding: 2px 8px; border-radius: 20px; letter-spacing: .04em;
    }
</style>

<div class="container-fluid py-3">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h4 class="text-white mb-0"><i class="bi bi-briefcase me-2 text-primary"></i>Puestos / Cargos</h4>
            <small class="text-muted">Catalogo de puestos laborales - Human Resources</small>
        </div>
        <div class="d-flex gap-2">
            <a href="/HR/Employees" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-people me-1"></i>Empleados
            </a>
            <button class="btn btn-primary" onclick="POS.openModal()">
                <i class="bi bi-plus-lg me-1"></i>Nuevo Puesto
            </button>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card bg-dark border-secondary mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary"
                           id="posSearch" placeholder="Buscar por nombre o codigo..." oninput="POS.debounceSearch()">
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm bg-dark text-white border-secondary" id="posFilterDept" onchange="POS.load()">
                        <option value="">Todos los departamentos</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm bg-dark text-white border-secondary" id="posFilterActive" onchange="POS.load()">
                        <option value="">Todos</option>
                        <option value="true" selected>Activos</option>
                        <option value="false">Inactivos</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-outline-secondary" onclick="POS.load()"><i class="bi bi-arrow-clockwise"></i></button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card bg-dark border-secondary">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Codigo</th>
                            <th>Nombre</th>
                            <th>Departamento</th>
                            <th>Nivel</th>
                            <th class="text-center">Conductor</th>
                            <th>Descripcion</th>
                            <th>Orden</th>
                            <th class="text-center">Estado</th>
                            <th style="width:80px"></th>
                        </tr>
                    </thead>
                    <tbody id="posBody">
                        <tr><td colspan="8" class="text-center text-muted py-4">
                            <i class="bi bi-hourglass-split me-2"></i>Cargando...
                        </td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-dark border-secondary">
            <small class="text-muted" id="posPagInfo"></small>
        </div>
    </div>
</div>

<!-- MODAL PUESTO -->
<div class="modal fade" id="posModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary text-light">
            <div class="modal-header border-secondary py-2">
                <h5 class="modal-title" id="posModalTitle">
                    <i class="bi bi-briefcase me-2 text-primary"></i>Puesto
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label text-light">Codigo *</label>
                        <input class="form-control bg-dark text-white border-secondary" id="posCode" maxlength="30" placeholder="GER-GEN">
                    </div>
                    <div class="col-md-8">
                        <label class="form-label text-light">Nombre *</label>
                        <input class="form-control bg-dark text-white border-secondary" id="posName" maxlength="150">
                    </div>
                    <div class="col-12">
                        <label class="form-label text-light">Departamento *</label>
                        <select class="form-select bg-dark text-white border-secondary" id="posDepartment">
                            <option value="">- Seleccione departamento -</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-light">Nivel</label>
                        <input class="form-control bg-dark text-white border-secondary" id="posLevel" maxlength="60" placeholder="Ej: Gerencia, Jefatura, Analista...">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-light">Orden</label>
                        <input type="number" class="form-control bg-dark text-white border-secondary" id="posSortOrder" value="0" min="0">
                    </div>
                    <div class="col-md-3 d-flex align-items-end pb-1">
                        <div class="d-flex flex-column gap-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="posIsActive" checked>
                                <label class="form-check-label text-light" for="posIsActive">Activo</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="posIsDriver">
                                <label class="form-check-label text-light" for="posIsDriver">Es Conductor</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-light">Descripcion</label>
                        <textarea class="form-control bg-dark text-white border-secondary" id="posDescription" rows="2" maxlength="500"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="posBtnSave" onclick="POS.save()">
                    <i class="bi bi-floppy me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Eliminar -->
<div class="modal fade" id="posDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-danger text-light">
            <div class="modal-header border-danger">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Eliminar Puesto</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Eliminar el puesto <strong id="posDeleteName"></strong>?</p>
                <small class="text-danger">Si el puesto esta asignado a empleados no se podra eliminar.</small>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" onclick="POS.confirmDelete()"><i class="bi bi-trash me-1"></i>Eliminar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    window.POS_API   = '@ViewBag.ApiBaseUrl';
    window.POS_TOKEN = '@ViewBag.ApiToken';
</script>
<script src="~/js/positions.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        ['posModal','posDeleteModal'].forEach(function(id){
            var el = document.getElementById(id);
            if (el) document.body.appendChild(el);
        });
    });
</script>
}
