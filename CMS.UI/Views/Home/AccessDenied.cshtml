@* ================================================================================ *@
@* ARCHIVO: CMS.UI/Views/Home/AccessDenied.cshtml                                *@
@* PROPÓSITO: Página de acceso denegado por falta de permisos                   *@
@* AUTOR: EAMR, BITI SOLUTIONS S.A                                              *@
@* CREADO: 2026-03-02                                                           *@
@* ================================================================================ *@

@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "_Layout";
    
    var permission = ViewData["Permission"] as string;
    var permissionDisplayName = ViewData["PermissionDisplayName"] as string ?? "esta funcionalidad";
    var returnUrl = ViewData["ReturnUrl"] as string ?? "/Home";
}

<style>
    .access-denied-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        text-align: center;
        padding: 40px 20px;
    }

    .access-denied-icon {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.2) 0%, rgba(185, 28, 28, 0.3) 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 30px;
        animation: pulse-red 2s infinite;
    }

    .access-denied-icon i {
        font-size: 60px;
        color: #ef4444;
    }

    @@keyframes pulse-red {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4);
        }
        50% {
            box-shadow: 0 0 30px 10px rgba(239, 68, 68, 0.2);
        }
    }

    .access-denied-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #ef4444;
        margin-bottom: 15px;
    }

    .access-denied-subtitle {
        font-size: 1.2rem;
        color: #94a3b8;
        margin-bottom: 30px;
        max-width: 500px;
    }

    .permission-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 30px;
        padding: 12px 24px;
        color: #fca5a5;
        font-size: 0.95rem;
        margin-bottom: 30px;
    }

    .permission-badge i {
        color: #ef4444;
    }

    .help-text {
        background: rgba(6, 182, 212, 0.1);
        border: 1px solid rgba(6, 182, 212, 0.2);
        border-radius: 12px;
        padding: 20px 30px;
        color: #94a3b8;
        font-size: 0.95rem;
        max-width: 600px;
        margin-bottom: 30px;
    }

    .help-text strong {
        color: #22d3ee;
    }

    .action-buttons {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .btn-go-back {
        background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);
        border: none;
        padding: 12px 30px;
        border-radius: 10px;
        color: white;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .btn-go-back:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(6, 182, 212, 0.3);
        color: white;
    }

    .btn-contact {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 12px 30px;
        border-radius: 10px;
        color: #94a3b8;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .btn-contact:hover {
        border-color: rgba(255, 255, 255, 0.4);
        color: white;
    }
</style>

<div class="content-container">
    <div class="access-denied-container">
        <div class="access-denied-icon">
            <i class="bi bi-shield-lock"></i>
        </div>

        <h1 class="access-denied-title">Acceso Denegado</h1>
        
        <p class="access-denied-subtitle">
            No tiene los permisos necesarios para acceder a @permissionDisplayName.
        </p>

        @if (!string.IsNullOrEmpty(permission))
        {
            <div class="permission-badge">
                <i class="bi bi-key"></i>
                <span>Permiso requerido: <code>@permission</code></span>
            </div>
        }

        <div class="help-text">
            <i class="bi bi-info-circle me-2"></i>
            Si necesita acceso a esta funcionalidad, contacte al <strong>administrador del sistema</strong> 
            para que le asigne los permisos correspondientes.
        </div>

        <div class="action-buttons">
            <a href="@returnUrl" class="btn-go-back">
                <i class="bi bi-arrow-left"></i>
                Volver
            </a>
            <a href="/Home" class="btn-contact">
                <i class="bi bi-house"></i>
                Ir al Dashboard
            </a>
        </div>
    </div>
</div>
