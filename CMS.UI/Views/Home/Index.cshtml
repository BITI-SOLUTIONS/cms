@* ================================================================================ *@
@* ARCHIVO: CMS.UI/Views/Home/Index.cshtml                                         *@
@* PROPÓSITO: Dashboard Principal del Sistema CMS                                  *@
@* DESCRIPCIÓN: Panel de control con métricas, accesos rápidos y actividad        *@
@* AUTOR: EAMR, BITI SOLUTIONS S.A                                                 *@
@* ACTUALIZADO: 2026-02-27 - Estadísticas dinámicas desde BD                       *@
@* ================================================================================ *@

@using CMS.UI.Services

@{
    ViewData["Title"] = "Dashboard";
    var userName = User.Identity?.Name ?? "Usuario";
    var displayName = userName.Contains("@") ? userName.Split('@')[0] : userName;
    var greeting = DateTime.Now.Hour < 12 ? "Buenos días" : DateTime.Now.Hour < 18 ? "Buenas tardes" : "Buenas noches";

    // Obtener estadísticas del Dashboard
    var stats = ViewData["DashboardStats"] as DashboardStatsViewModel ?? new DashboardStatsViewModel();

    // Permisos para accesos rápidos
    var hasUsersPermission = ViewData["HasUsersPermission"] as bool? ?? false;
    var hasRolesPermission = ViewData["HasRolesPermission"] as bool? ?? false;
    var hasMenusPermission = ViewData["HasMenusPermission"] as bool? ?? false;
    var hasCompaniesPermission = ViewData["HasCompaniesPermission"] as bool? ?? false;
}

<style>
    /* Dashboard specific styles */
    .dashboard-header {
        margin-bottom: 30px;
    }

    .welcome-text {
        font-size: 2rem;
        font-weight: 700;
        background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 5px;
    }

    .welcome-subtitle {
        color: var(--text-gray);
        font-size: 0.95rem;
    }

    .user-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(6, 182, 212, 0.1);
        border: 1px solid var(--border-color);
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 0.85rem;
        color: var(--text-gray);
    }

    .user-badge i {
        color: var(--accent-cyan);
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-white);
    }

    .section-title i {
        color: var(--accent-cyan);
    }

    /* Quick action cards */
    .quick-action {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 25px;
        text-align: center;
        transition: all 0.3s ease;
        cursor: pointer;
        text-decoration: none;
        display: block;
        height: 100%;
    }

    .quick-action:hover {
        transform: translateY(-5px);
        border-color: var(--border-glow);
        box-shadow: 0 15px 40px rgba(6, 182, 212, 0.2);
    }

    .quick-action .action-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 1.5rem;
        transition: all 0.3s ease;
    }

    .quick-action:hover .action-icon {
        transform: scale(1.1);
    }

    .quick-action .action-icon.cyan {
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.2) 0%, rgba(6, 182, 212, 0.1) 100%);
        color: var(--accent-cyan);
    }

    .quick-action .action-icon.blue {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.2) 0%, rgba(59, 130, 246, 0.1) 100%);
        color: var(--accent-blue);
    }

    .quick-action .action-icon.purple {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.2) 0%, rgba(139, 92, 246, 0.1) 100%);
        color: #8b5cf6;
    }

    .quick-action .action-icon.green {
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.2) 0%, rgba(16, 185, 129, 0.1) 100%);
        color: var(--accent-green);
    }

    .quick-action h5 {
        color: var(--text-white);
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 1rem;
    }

    .quick-action p {
        color: var(--text-gray);
        font-size: 0.85rem;
        margin: 0;
    }

    /* Activity list */
    .activity-item {
        display: flex;
        align-items: flex-start;
        gap: 15px;
        padding: 15px 0;
        border-bottom: 1px solid var(--border-color);
    }

    .activity-item:last-child {
        border-bottom: none;
    }

    .activity-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .activity-icon.success {
        background: rgba(16, 185, 129, 0.15);
        color: var(--accent-green);
    }

    .activity-icon.info {
        background: rgba(6, 182, 212, 0.15);
        color: var(--accent-cyan);
    }

    .activity-icon.warning {
        background: rgba(245, 158, 11, 0.15);
        color: #f59e0b;
    }

    .activity-content {
        flex: 1;
    }

    .activity-content strong {
        color: var(--text-white);
    }

    .activity-content span {
        color: var(--text-gray);
        font-size: 0.9rem;
    }

    .activity-time {
        color: var(--text-dark);
        font-size: 0.8rem;
    }

    /* System status */
    .status-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid var(--border-color);
    }

    .status-item:last-child {
        border-bottom: none;
    }

    .status-label {
        color: var(--text-gray);
        font-size: 0.9rem;
    }

    .status-value {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    .status-dot.online {
        background: var(--accent-green);
        box-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
    }

    .status-dot.warning {
        background: #f59e0b;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    /* Help card */
    .help-card {
        background: linear-gradient(135deg, rgba(6, 182, 212, 0.1) 0%, rgba(59, 130, 246, 0.1) 100%);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 25px;
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .help-icon {
        width: 50px;
        height: 50px;
        background: var(--accent-gradient);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
        flex-shrink: 0;
    }

    .help-content h5 {
        color: var(--text-white);
        margin-bottom: 5px;
    }

    .help-content p {
        color: var(--text-gray);
        margin: 0;
        font-size: 0.9rem;
    }

    .help-content a {
        color: var(--accent-cyan);
        text-decoration: none;
    }

    .help-content a:hover {
        text-decoration: underline;
    }
</style>

<div class="container-fluid">

    @* ========================================================================== *@
    @* HEADER DEL DASHBOARD                                                       *@
    @* ========================================================================== *@
    <div class="dashboard-header">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1 class="welcome-text">@greeting, @displayName 👋</h1>
                <p class="welcome-subtitle">
                    @stats.WelcomeMessage
                </p>
            </div>
            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                <div class="user-badge">
                    <i class="bi bi-clock"></i>
                    @DateTime.Now.ToString("dddd, dd MMMM yyyy")
                </div>
            </div>
        </div>
    </div>

    @* ========================================================================== *@
    @* TARJETAS DE ESTADÍSTICAS                                                   *@
    @* ========================================================================== *@
    <div class="row mb-4">
        <div class="col-lg-3 col-md-6 mb-4">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label">Usuarios Activos</p>
                        <h2 class="stat-value">@stats.ActiveUsers.ToString("N0")</h2>
                        <div class="stat-change positive">
                            <i class="bi bi-people"></i>
                            <span>En esta compañía</span>
                        </div>
                    </div>
                    <div class="stat-icon cyan">
                        <i class="bi bi-people"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label">Roles Configurados</p>
                        <h2 class="stat-value">@stats.TotalRoles.ToString("N0")</h2>
                        <div class="stat-change positive">
                            <i class="bi bi-check-circle"></i>
                            <span>Disponibles</span>
                        </div>
                    </div>
                    <div class="stat-icon purple">
                        <i class="bi bi-shield-check"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label">Permisos</p>
                        <h2 class="stat-value">@stats.TotalPermissions.ToString("N0")</h2>
                        <div class="stat-change positive">
                            <i class="bi bi-key"></i>
                            <span>Configurados</span>
                        </div>
                    </div>
                    <div class="stat-icon blue">
                        <i class="bi bi-key"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="stat-label">Módulos Activos</p>
                        <h2 class="stat-value">@stats.ActiveModules.ToString("N0")</h2>
                        <div class="stat-change positive">
                            <i class="bi bi-lightning"></i>
                            <span>Operativos</span>
                        </div>
                    </div>
                    <div class="stat-icon green">
                        <i class="bi bi-grid-3x3-gap"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ========================================================================== *@
    @* ACCESOS RÁPIDOS                                                            *@
    @* ========================================================================== *@
    <div class="mb-4">
        <div class="section-title">
            <i class="bi bi-lightning-charge-fill"></i>
            Accesos Rápidos
        </div>

        <div class="row">
            <div class="col-lg-3 col-md-6 mb-4">
                @if (hasUsersPermission)
                {
                    <a asp-controller="Users" asp-action="Index" asp-area="Admin" class="quick-action">
                        <div class="action-icon cyan">
                            <i class="bi bi-person-plus"></i>
                        </div>
                        <h5>Gestionar Usuarios</h5>
                        <p class="text-light">Crear, editar y administrar usuarios del sistema</p>
                    </a>
                }
                else
                {
                    <div class="quick-action" style="opacity: 0.6; cursor: not-allowed;" onclick="showNoPermissionAlert('Gestión de Usuarios')">
                        <div class="action-icon cyan">
                            <i class="bi bi-person-plus"></i>
                        </div>
                        <h5>Gestionar Usuarios</h5>
                        <p class="text-warning small"><i class="bi bi-lock me-1"></i>Requiere permiso</p>
                    </div>
                }
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                @{
                    var currentUserId = ViewData["CurrentUserId"] as int? ?? 1;
                    var currentCompanyId = ViewData["CurrentCompanyId"] as int? ?? 1;
                    var defaultRoleId = ViewData["DefaultRoleId"] as int? ?? 1;
                }
                @if (hasRolesPermission)
                {
                    <a href="/Roles/ManagePermissions/@defaultRoleId?userId=@currentUserId&companyId=@currentCompanyId" class="quick-action">
                        <div class="action-icon purple">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <h5>Roles y Permisos</h5>
                        <p class="text-light">Configurar roles y asignar permisos</p>
                    </a>
                }
                else
                {
                    <div class="quick-action" style="opacity: 0.6; cursor: not-allowed;" onclick="showNoPermissionAlert('Roles y Permisos')">
                        <div class="action-icon purple">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <h5>Roles y Permisos</h5>
                        <p class="text-warning small"><i class="bi bi-lock me-1"></i>Requiere permiso</p>
                    </div>
                }
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                @if (hasMenusPermission)
                {
                    <a asp-controller="Menus" asp-action="Index" class="quick-action">
                        <div class="action-icon blue">
                            <i class="bi bi-list-nested"></i>
                        </div>
                        <h5>Menú del Sistema</h5>
                        <p class="text-light">Administrar la estructura del menú</p>
                    </a>
                }
                else
                {
                    <div class="quick-action" style="opacity: 0.6; cursor: not-allowed;" onclick="showNoPermissionAlert('Menú del Sistema')">
                        <div class="action-icon blue">
                            <i class="bi bi-list-nested"></i>
                        </div>
                        <h5>Menú del Sistema</h5>
                        <p class="text-warning small"><i class="bi bi-lock me-1"></i>Requiere permiso</p>
                    </div>
                }
            </div>

            <div class="col-lg-3 col-md-6 mb-4">
                @if (hasCompaniesPermission)
                {
                    <a asp-controller="Companies" asp-action="Index" class="quick-action">
                        <div class="action-icon green">
                            <i class="bi bi-building"></i>
                        </div>
                        <h5>Compañías</h5>
                        <p class="text-light">Gestionar compañías y configuraciones</p>
                    </a>
                }
                else
                {
                    <div class="quick-action" style="opacity: 0.6; cursor: not-allowed;" onclick="showNoPermissionAlert('Gestión de Compañías')">
                        <div class="action-icon green">
                            <i class="bi bi-building"></i>
                        </div>
                        <h5>Compañías</h5>
                        <p class="text-warning small"><i class="bi bi-lock me-1"></i>Requiere permiso</p>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ========================================================================== *@
    @* ACTIVIDAD Y ESTADO DEL SISTEMA                                             *@
    @* ========================================================================== *@
    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-clock-history me-2"></i>
                    Actividad Reciente
                </div>
                <div class="card-body">
                    <div class="activity-item">
                        <div class="activity-icon success">
                            <i class="bi bi-person-check"></i>
                        </div>
                        <div class="activity-content">
                            <strong>@displayName</strong>
                            <span>inició sesión en el sistema</span>
                        </div>
                        <div class="activity-time">Ahora</div>
                    </div>

                    <div class="activity-item">
                        <div class="activity-icon info">
                            <i class="bi bi-shield"></i>
                        </div>
                        <div class="activity-content">
                            <strong>Sistema</strong>
                            <span>sincronizó permisos de usuario</span>
                        </div>
                        <div class="activity-time">Hace 2 min</div>
                    </div>

                    <div class="activity-item">
                        <div class="activity-icon warning">
                            <i class="bi bi-database"></i>
                        </div>
                        <div class="activity-content">
                            <strong>Sistema</strong>
                            <span>realizó backup automático de la base de datos</span>
                        </div>
                        <div class="activity-time">Hace 1 hora</div>
                    </div>

                    <div class="activity-item">
                        <div class="activity-icon success">
                            <i class="bi bi-check-circle"></i>
                        </div>
                        <div class="activity-content">
                            <strong>Sistema</strong>
                            <span>completó verificación de integridad</span>
                        </div>
                        <div class="activity-time">Hace 3 horas</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card h-100">
                <div class="card-header">
                    <i class="bi bi-cpu me-2"></i>
                    Estado del Sistema
                </div>
                <div class="card-body">
                    <div class="status-item">
                        <span class="status-label">API</span>
                        <div class="status-value">
                            <span class="status-dot online"></span>
                            <span style="color: var(--accent-green);">Operativo</span>
                        </div>
                    </div>

                    <div class="status-item">
                        <span class="status-label">Base de Datos</span>
                        <div class="status-value">
                            <span class="status-dot online"></span>
                            <span style="color: var(--accent-green);">Conectado</span>
                        </div>
                    </div>

                    <div class="status-item">
                        <span class="status-label">Autenticación</span>
                        <div class="status-value">
                            <span class="status-dot online"></span>
                            <span style="color: var(--accent-green);">Activa</span>
                        </div>
                    </div>

                    <div class="status-item">
                        <span class="status-label">Último Backup</span>
                        <div class="status-value">
                            <span style="color: var(--text-gray);">Hace 1 hora</span>
                        </div>
                    </div>

                    <div class="status-item">
                        <span class="status-label">Versión</span>
                        <div class="status-value">
                            <span class="badge-tech cyan">v2.0.0</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* ========================================================================== *@
    @* AYUDA                                                                       *@
    @* ========================================================================== *@
    <div class="row">
        <div class="col-12">
            <div class="help-card">
                <div class="help-icon">
                    <i class="bi bi-lightbulb"></i>
                </div>
                <div class="help-content">
                    <h5>¿Necesitas ayuda?</h5>
                    <p>
                        Consulta la <a asp-controller="Documentation" asp-action="Index">documentación del sistema</a> o 
                        contacta al equipo de soporte técnico de BITI Solutions.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log('✅ Dashboard Tech cargado correctamente');

            // Animación de entrada para las cards
            const cards = document.querySelectorAll('.stat-card, .quick-action, .card');
            cards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.5s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 100);
            });
        });

        // Función para mostrar alerta de sin permiso
        function showNoPermissionAlert(moduleName) {
            // Crear el toast
            const toastHtml = `
                <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
                    <div class="toast show" role="alert" style="background: var(--bg-card); border: 1px solid #dc3545;">
                        <div class="toast-header" style="background: rgba(220, 53, 69, 0.2); color: #dc3545;">
                            <i class="bi bi-shield-exclamation me-2"></i>
                            <strong class="me-auto">Acceso Denegado</strong>
                            <button type="button" class="btn-close btn-close-white" onclick="this.closest('.toast-container').remove()"></button>
                        </div>
                        <div class="toast-body text-light">
                            <p class="mb-0">No tienes permisos para acceder a <strong>${moduleName}</strong>.</p>
                            <small class="text-muted">Contacta al administrador si necesitas acceso.</small>
                        </div>
                    </div>
                </div>
            `;

            // Remover toasts anteriores
            document.querySelectorAll('.toast-container').forEach(el => el.remove());

            // Agregar el nuevo toast
            document.body.insertAdjacentHTML('beforeend', toastHtml);

            // Auto-ocultar después de 5 segundos
            setTimeout(() => {
                document.querySelectorAll('.toast-container').forEach(el => el.remove());
            }, 5000);
        }
    </script>
}