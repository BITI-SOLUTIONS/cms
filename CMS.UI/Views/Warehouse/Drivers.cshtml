@* ================================================================================
   VISTA: CMS.UI/Views/Warehouse/Drivers.cshtml
   PROPÓSITO: Gestión de conductores de la flota
   ================================================================================ *@
@{
    ViewData["Title"] = "Conductores";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    small, .form-text, small.text-muted, .text-muted small { color: #cbd5e1 !important; }
    .driver-avatar { width: 36px; height: 36px; border-radius: 50%; background: #3b82f6;
                     display: inline-flex; align-items: center; justify-content: center;
                     font-weight: 700; font-size: .85rem; color: #fff; }
    .badge-license { font-size: .7rem; }
    .expiry-warn   { color: #f59e0b !important; }
    .expiry-danger { color: #ef4444 !important; }
</style>

<div class="container-fluid py-3">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h4 class="text-white mb-0"><i class="bi bi-person-badge me-2 text-success"></i>Conductores</h4>
            <small class="text-muted">Registro y mantenimiento de conductores de la flota</small>
        </div>
        <button class="btn btn-primary" onclick="DRV.openModal()">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Conductor
        </button>
    </div>

    <!-- KPIs -->
    <div class="row g-2 mb-3" id="drvKpis">
        <div class="col-6 col-md-3">
            <div class="card bg-dark border-secondary text-center py-2">
                <div class="fs-4 text-primary fw-bold" id="kpiTotal">—</div>
                <small class="text-muted">Total</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-dark border-secondary text-center py-2">
                <div class="fs-4 text-success fw-bold" id="kpiActive">—</div>
                <small class="text-muted">Activos</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-dark border-secondary text-center py-2">
                <div class="fs-4 text-warning fw-bold" id="kpiExpiring">—</div>
                <small class="text-muted">Licencia por vencer</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card bg-dark border-secondary text-center py-2">
                <div class="fs-4 text-danger fw-bold" id="kpiExpired">—</div>
                <small class="text-muted">Licencia vencida</small>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card bg-dark border-secondary mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-5">
                    <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary"
                           id="drvSearch" placeholder="Buscar por nombre, cédula, licencia, email…"
                           oninput="DRV.debounceSearch()">
                </div>
                <div class="col-md-3">
                    <select class="form-select form-select-sm bg-dark text-white border-secondary" id="drvFilterActive" onchange="DRV.load()">
                        <option value="">Todos</option>
                        <option value="true" selected>Activos</option>
                        <option value="false">Inactivos</option>
                    </select>
                </div>
                <div class="col-md-auto">
                    <button class="btn btn-sm btn-outline-secondary" onclick="DRV.load()">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card bg-dark border-secondary">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0">
                    <thead>
                        <tr>
                            <th></th>
                            <th>Código</th>
                            <th>Nombre</th>
                            <th>Identificación</th>
                            <th>Licencia</th>
                            <th>Vence</th>
                            <th>Teléfono</th>
                            <th>Usuario Sistema</th>
                            <th class="text-center">Activo</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="drvBody">
                        <tr><td colspan="10" class="text-center text-muted py-4">
                            <i class="bi bi-hourglass-split"></i> Cargando…
                        </td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-dark border-secondary d-flex justify-content-between align-items-center py-2">
            <small class="text-muted" id="drvPagInfo"></small>
            <div id="drvPagNav"></div>
        </div>
    </div>
</div>

<!-- ============================================================
     MODAL CONDUCTOR
     ============================================================ -->
<div class="modal fade" id="drvModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content bg-dark border-secondary text-light">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="drvModalTitle">Conductor</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <!-- Tabs del formulario -->
                <ul class="nav nav-tabs mb-3" id="drvFormTabs">
                    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#drvTabPersonal"><i class="bi bi-person me-1"></i>Datos Personales</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#drvTabLicense"><i class="bi bi-card-text me-1"></i>Licencia</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#drvTabEmergency"><i class="bi bi-heart-pulse me-1"></i>Emergencia</a></li>
                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#drvTabSystem"><i class="bi bi-person-gear me-1"></i>Usuario Sistema</a></li>
                </ul>
                <div class="tab-content">

                    <!-- Datos Personales -->
                    <div class="tab-pane fade show active" id="drvTabPersonal">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label text-light">Código *</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvCode" maxlength="30">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-light">Tipo ID</label>
                                <select class="form-select bg-dark text-white border-secondary" id="drvIdType">
                                    <option value="CEDULA">Cédula Nacional</option>
                                    <option value="PASSPORT">Pasaporte</option>
                                    <option value="DIMEX">DIMEX</option>
                                    <option value="OTHER">Otro</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-light">Número de ID *</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvIdNumber" maxlength="30">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label text-light">Fecha Contratación</label>
                                <input type="date" class="form-control bg-dark text-white border-secondary" id="drvHireDate">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-light">Primer Nombre *</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvFirstName" maxlength="80">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-light">Primer Apellido *</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvLastName" maxlength="80">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-light">Segundo Apellido</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvSecondLastName" maxlength="80">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-light">Teléfono</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvPhone" maxlength="20">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-light">Móvil</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvMobile" maxlength="20">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-light">Correo Electrónico</label>
                                <input type="email" class="form-control bg-dark text-white border-secondary" id="drvEmail" maxlength="150">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-light">Puesto / Cargo</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvPosition" maxlength="100">
                            </div>
                            <div class="col-12">
                                <label class="form-label text-light">Dirección</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvAddress" maxlength="500">
                            </div>
                            <div class="col-12">
                                <label class="form-label text-light">Notas</label>
                                <textarea class="form-control bg-dark text-white border-secondary" id="drvNotes" rows="2" maxlength="2000"></textarea>
                            </div>
                            <div class="col-12">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="drvIsActive" checked>
                                    <label class="form-check-label text-light" for="drvIsActive">Activo</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Licencia -->
                    <div class="tab-pane fade" id="drvTabLicense">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label text-light">Número de Licencia</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvLicenseNumber" maxlength="30">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-light">Categoría</label>
                                <select class="form-select bg-dark text-white border-secondary" id="drvLicenseCategory">
                                    <option value="">Seleccione…</option>
                                    <option value="B1">B1 - Vehículo liviano</option>
                                    <option value="B2">B2 - Motocicleta</option>
                                    <option value="C1">C1 - Transporte de carga liviana</option>
                                    <option value="C2">C2 - Transporte de carga pesada</option>
                                    <option value="D1">D1 - Transporte de pasajeros</option>
                                    <option value="D2">D2 - Transporte de pasajeros (bus)</option>
                                    <option value="E">E - Maquinaria especial</option>
                                    <option value="OTHER">Otro</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-light">Fecha de Vencimiento</label>
                                <input type="date" class="form-control bg-dark text-white border-secondary" id="drvLicenseExpiry">
                                <small id="drvExpiryMsg"></small>
                            </div>
                        </div>
                    </div>

                    <!-- Contacto de Emergencia -->
                    <div class="tab-pane fade" id="drvTabEmergency">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label text-light">Nombre de Contacto</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvEmergencyName" maxlength="200">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-light">Teléfono de Contacto</label>
                                <input class="form-control bg-dark text-white border-secondary" id="drvEmergencyPhone" maxlength="30">
                            </div>
                        </div>
                    </div>

                    <!-- Usuario del Sistema -->
                    <div class="tab-pane fade" id="drvTabSystem">
                        <p class="text-muted">
                            <i class="bi bi-info-circle me-1"></i>
                            Vincule este conductor a un usuario activo del sistema para acceso a la aplicación.
                        </p>
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label text-light">Usuario del Sistema</label>
                                <select class="form-select bg-dark text-white border-secondary" id="drvSystemUser">
                                    <option value="">— Sin usuario vinculado —</option>
                                </select>
                                <small>Solo usuarios activos de la compañía actual</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="drvBtnSave" onclick="DRV.save()">
                    <i class="bi bi-floppy me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Eliminar/Desactivar -->
<div class="modal fade" id="drvDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-danger text-light">
            <div class="modal-header border-danger">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Desactivar Conductor</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Desea desactivar al conductor <strong id="drvDeleteName"></strong>?</p>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" onclick="DRV.confirmDelete()">
                    <i class="bi bi-trash me-1"></i>Desactivar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    window.DRV_API   = '@ViewBag.ApiBaseUrl';
    window.DRV_TOKEN = '@ViewBag.ApiToken';
</script>
<script src="~/js/drivers.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        ['drvModal','drvDeleteModal'].forEach(function(id){
            var el = document.getElementById(id);
            if (el) document.body.appendChild(el);
        });
    });
</script>
}
