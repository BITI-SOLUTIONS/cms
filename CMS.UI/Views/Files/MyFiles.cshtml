@{
    ViewData["Title"] = "Mis Archivos";
    ViewData["Subtitle"] = "Archivos creados por mí";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 text-light">
                <i class="bi bi-person-fill-gear me-2"></i>@ViewData["Title"]
            </h1>
            <p class="text-muted mb-0">@ViewData["Subtitle"]</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary" id="btnUpload">
                <i class="bi bi-cloud-upload me-2"></i>Subir Archivo
            </button>
        </div>
    </div>

    <!-- Content -->
    <div class="card bg-dark border-secondary">
        <div class="card-body">
            <div class="text-center py-5">
                <i class="bi bi-person-fill-gear text-info" style="font-size: 4rem;"></i>
                <h4 class="text-light mt-3">Mis Archivos</h4>
                <p class="text-muted">
                    Aquí verás todos los archivos que has subido al sistema.
                    <br>Esta funcionalidad está en desarrollo.
                </p>
                <a href="/Files/Master" class="btn btn-outline-info mt-2">
                    <i class="bi bi-folder2-open me-2"></i>Ir al Explorador de Archivos
                </a>
            </div>
        </div>
    </div>
</div>
