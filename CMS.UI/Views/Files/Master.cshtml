        // ================================================================
        // CARGAR ÁRBOL DE CARPETAS EN SIDEBAR (JERÁRQUICO)
        // ================================================================
        let allFoldersCache = []; // Cache de todas las carpetas para el árbol

        async function loadFolderTree() {
            console.log('🌳 loadFolderTree() iniciando...');
            const folderTree = document.getElementById('folderTree');

            try {
                // Cargar TODAS las carpetas sin filtrar por parentId para construir el árbol completo
                const response = await fetch('/Files/GetContents');
                if (!response.ok) throw new Error(`HTTP ${response.status}`);

                const data = await response.json();
                allFoldersCache = data.folders || [];

                // Filtrar solo carpetas raíz (sin parentId o parentId = null)
                const rootFolders = allFoldersCache.filter(f => !f.parentId);

                if (allFoldersCache.length === 0) {
                    folderTree.innerHTML = `
                        <div class="text-center text-light opacity-75 py-3">
                            <i class="bi bi-folder-x fs-4"></i>
                            <p class="small mt-2 mb-0">Sin carpetas</p>
                        </div>
                    `;
                    return;
                }

                folderTree.innerHTML = '';

                // Agregar carpeta raíz (Home) - también es zona de drop
                const rootItem = document.createElement('div');
                rootItem.className = 'folder-tree-item d-flex align-items-center p-2 rounded mb-1 text-light';
                rootItem.setAttribute('data-folder-id', '');
                rootItem.setAttribute('data-folder-name', 'Raíz');
                rootItem.style.cursor = 'pointer';
                rootItem.innerHTML = `
                    <i class="bi bi-house-door me-2 text-info"></i>
                    <span class="small">Raíz</span>
                `;
                rootItem.onclick = () => window.navigateToFolder(null);

                // ★ Hacer que la raíz sea zona de drop
                console.log('🎯 Configurando drop target para RAÍZ...');
                window.makeFolderDropTarget(rootItem, null, 'Raíz');
                console.log('✅ Drop target configurado para RAÍZ');

                folderTree.appendChild(rootItem);

                // Agregar SOLO carpetas raíz con posibilidad de expandir
                rootFolders.forEach(folder => {
                    const hasChildren = allFoldersCache.some(f => f.parentId === folder.id);
                    const folderContainer = createFolderTreeItem(folder, 0, hasChildren);
                    folderTree.appendChild(folderContainer);
                });

                console.log('🌳 loadFolderTree() completado - Drop targets configurados:', rootFolders.length + 1);

            } catch (error) {
                console.error('❌ Error cargando árbol de carpetas:', error);
                folderTree.innerHTML = `
                    <div class="text-center text-danger py-3">
                        <i class="bi bi-exclamation-triangle fs-4"></i>
                        <p class="small mt-2 mb-0">Error cargando</p>
                    </div>
                `;
            }
        }

        // Crear elemento de carpeta en el árbol con soporte para expandir/colapsar y drop
        function createFolderTreeItem(folder, level, hasChildren) {
            const container = document.createElement('div');
            container.className = 'folder-tree-container';
            container.setAttribute('data-folder-container', folder.id);

            const item = document.createElement('div');
            item.className = 'folder-tree-item d-flex align-items-center p-2 rounded mb-1 text-light';
            item.setAttribute('data-folder-id', folder.id);
            item.setAttribute('data-folder-name', folder.name);
            item.style.cursor = 'pointer';
            item.style.paddingLeft = `${(level * 16) + 8}px`;

            const expandIcon = hasChildren ? 'bi-chevron-right' : '';
            const expandHtml = hasChildren 
                ? `<i class="bi ${expandIcon} me-1 expand-icon" style="font-size: 0.7rem; transition: transform 0.2s;"></i>` 
                : `<span style="width: 14px; display: inline-block;"></span>`;

            item.innerHTML = `
                ${expandHtml}
                <i class="bi ${folder.icon || 'bi-folder-fill'} me-2" style="color: ${folder.color || '#fbbf24'}"></i>
                <span class="small text-truncate" title="${folder.name}">${folder.name}</span>
            `;

            // Click en la carpeta: navegar
            item.onclick = (e) => {
                e.stopPropagation();
                window.navigateToFolder(folder.id);
                // Si tiene hijos, también expandir/colapsar
                if (hasChildren) {
                    toggleFolderChildren(folder.id, container, level);
                }
            };

            item.onmouseover = () => item.classList.add('bg-secondary', 'bg-opacity-50');
            item.onmouseout = () => { if (!item.classList.contains('active')) item.classList.remove('bg-secondary', 'bg-opacity-50'); };

            // ★ Hacer que sea zona de drop para drag-and-drop
            console.log('🎯 Configurando drop target para carpeta:', folder.name, 'ID:', folder.id);
            window.makeFolderDropTarget(item, folder.id, folder.name);

            container.appendChild(item);

            // Contenedor para hijos (inicialmente oculto)
            if (hasChildren) {
                const childrenContainer = document.createElement('div');
                childrenContainer.className = 'folder-children d-none';
                childrenContainer.setAttribute('data-children-of', folder.id);
                container.appendChild(childrenContainer);
            }

            return container;
        }

        // Expandir/colapsar hijos de una carpeta
        function toggleFolderChildren(parentId, container, parentLevel) {
            const childrenContainer = container.querySelector(`[data-children-of="${parentId}"]`);
            const expandIcon = container.querySelector('.expand-icon');

            if (!childrenContainer) return;

            const isExpanded = !childrenContainer.classList.contains('d-none');

            if (isExpanded) {
                // Colapsar
                childrenContainer.classList.add('d-none');
                if (expandIcon) {
                    expandIcon.classList.remove('bi-chevron-down');
                    expandIcon.classList.add('bi-chevron-right');
                    expandIcon.style.transform = 'rotate(0deg)';
                }
            } else {
                // Expandir: cargar hijos si no están cargados
                if (childrenContainer.children.length === 0) {
                    const children = allFoldersCache.filter(f => f.parentId === parentId);
                    children.forEach(child => {
                        const hasGrandchildren = allFoldersCache.some(f => f.parentId === child.id);
                        const childItem = createFolderTreeItem(child, parentLevel + 1, hasGrandchildren);
                        childrenContainer.appendChild(childItem);
                    });
                }
                childrenContainer.classList.remove('d-none');
                if (expandIcon) {
                    expandIcon.classList.remove('bi-chevron-right');
                    expandIcon.classList.add('bi-chevron-down');
                    expandIcon.style.transform = 'rotate(0deg)';
                }
            }
        }

        function getFileIconFromExtension(ext) {
            if (!ext) return 'bi-file-earmark';
            ext = ext.toLowerCase().replace('.', '');
            const icons = {
                'pdf': 'bi-file-pdf',
                'doc': 'bi-file-word', 'docx': 'bi-file-word',
                'xls': 'bi-file-excel', 'xlsx': 'bi-file-excel',
                'ppt': 'bi-file-ppt', 'pptx': 'bi-file-ppt',
                'jpg': 'bi-file-image', 'jpeg': 'bi-file-image', 'png': 'bi-file-image', 'gif': 'bi-file-image', 'webp': 'bi-file-image',
                'mp4': 'bi-file-play', 'avi': 'bi-file-play', 'mov': 'bi-file-play',
                'mp3': 'bi-file-music', 'wav': 'bi-file-music',
                'zip': 'bi-file-zip', 'rar': 'bi-file-zip', '7z': 'bi-file-zip',
                'txt': 'bi-file-text', 'csv': 'bi-file-text',
                'html': 'bi-file-code', 'css': 'bi-file-code', 'js': 'bi-file-code', 'json': 'bi-file-code'
            };
            return icons[ext] || 'bi-file-earmark';
        }

        function formatDate(dateStr) {
            if (!dateStr) return '-';
            const date = new Date(dateStr);
            return date.toLocaleDateString('es-CR', { day: '2-digit', month: 'short', year: 'numeric' });
        }

        // ================================================================
        // DRAG AND DROP - MOVER CARPETAS
        // ================================================================
        // ⚠️ IMPORTANTE: Estas funciones DEBEN definirse ANTES de loadFolderTree()
        // porque loadFolderTree() las usa al crear los elementos del árbol
        let draggedFolderId = null;
        let draggedFolderName = null;

        // Hacer que las carpetas del grid sean arrastrables
        window.makeFolderDraggable = function(element, folderId, folderName) {
            console.log('🔧 makeFolderDraggable llamado para:', folderName, 'ID:', folderId, 'Tipo:', typeof folderId);
            element.setAttribute('draggable', 'true');
            element.style.cursor = 'grab';

            element.addEventListener('dragstart', function(e) {
                console.log('🚀 DRAGSTART iniciado para:', folderName, 'ID:', folderId);
                draggedFolderId = folderId;
                draggedFolderName = folderName;
                e.dataTransfer.setData('text/plain', String(folderId));
                e.dataTransfer.effectAllowed = 'move';
                element.style.opacity = '0.5';
                element.classList.add('dragging');

                // Activar zonas de drop en el árbol
                document.querySelectorAll('.folder-tree-item, .folder-tree-drop-zone').forEach(item => {
                    item.classList.add('drop-target-active');
                });
                console.log('✅ draggedFolderId establecido a:', draggedFolderId, 'Tipo:', typeof draggedFolderId);
            });

            element.addEventListener('dragend', function(e) {
                console.log('🛑 DRAGEND - limpiando estado');
                element.style.opacity = '1';
                element.classList.remove('dragging');
                draggedFolderId = null;
                draggedFolderName = null;

                // Desactivar zonas de drop
                document.querySelectorAll('.folder-tree-item, .folder-tree-drop-zone').forEach(item => {
                    item.classList.remove('drop-target-active', 'drop-target-hover');
                });
            });
        };

        // Configurar carpetas del sidebar como zonas de drop
        window.makeFolderDropTarget = function(element, targetFolderId, targetFolderName) {
            console.log('🎯 makeFolderDropTarget llamado para:', targetFolderName, 'ID:', targetFolderId, 'Tipo:', typeof targetFolderId);

            element.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.stopPropagation();

                console.log('📍 DRAGOVER en:', targetFolderName, '| draggedId:', draggedFolderId, '('+typeof draggedFolderId+')', '| targetId:', targetFolderId, '('+typeof targetFolderId+')');

                // No permitir drop en sí mismo (comparación flexible para evitar problemas de tipo)
                if (String(draggedFolderId) === String(targetFolderId)) {
                    console.log('❌ Auto-drop detectado, bloqueando');
                    e.dataTransfer.dropEffect = 'none';
                    return;
                }

                console.log('✅ Drop permitido, estableciendo dropEffect=move');

                e.dataTransfer.dropEffect = 'move';
                element.classList.add('drop-target-hover');
            });

            element.addEventListener('dragleave', function(e) {
                e.preventDefault();
                element.classList.remove('drop-target-hover');
                console.log('👋 DRAGLEAVE de:', targetFolderName);
            });

            element.addEventListener('drop', async function(e) {
                e.preventDefault();
                e.stopPropagation();
                element.classList.remove('drop-target-hover');

                const sourceIdStr = e.dataTransfer.getData('text/plain');
                const sourceFolderId = parseInt(sourceIdStr);

                console.log('💧 DROP en:', targetFolderName, '| sourceId:', sourceFolderId, '| targetId:', targetFolderId);

                // No permitir drop en sí mismo (comparar como números)
                const targetIdNum = targetFolderId === null ? null : parseInt(targetFolderId);
                if (sourceFolderId === targetIdNum) {
                    console.log('❌ Auto-drop en DROP, cancelando');
                    return;
                }

                // Confirmar la operación
                const targetName = targetFolderName || 'Raíz';
                const confirmMove = confirm(`¿Mover "${draggedFolderName}" a "${targetName}"?`);

                if (!confirmMove) return;

                console.log('📤 Enviando request MoveFolder:', { folderId: sourceFolderId, newParentId: targetIdNum });

                try {
                    const response = await fetch('/Files/MoveFolder', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            folderId: sourceFolderId,
                            newParentId: targetIdNum
                        })
                    });

                    if (response.ok) {
                        console.log('✅ Carpeta movida exitosamente');
                        // Refrescar ambas vistas
                        await loadFolderTree();
                        await loadContents(currentFolderId);
                    } else {
                        const error = await response.json();
                        console.error('❌ Error del servidor:', error);
                        alert('Error al mover la carpeta: ' + (error.message || 'Error desconocido'));
                    }
                } catch (error) {
                    console.error('❌ Error de red:', error);
                    alert('Error de conexión al mover la carpeta');
                }
            });
        };

        // ================================================================
        // CARGAR CONTENIDO AL INICIAR
        // ================================================================
        console.log('========================================');
        console.log('🚀 INICIALIZANDO FILE MASTER');
        console.log('makeFolderDraggable:', typeof window.makeFolderDraggable);
        console.log('makeFolderDropTarget:', typeof window.makeFolderDropTarget);
        console.log('========================================');

        // ★ Cache de contenido actual para búsqueda
        let currentFolders = [];
        let currentFiles = [];

        loadContents();
        loadFolderTree();

        // ================================================================
        // BÚSQUEDA EN EL SERVIDOR (RECURSIVA)
        // ================================================================
        const searchInput = document.getElementById('searchInput');
        let searchTimeout = null;
        let isSearching = false;

        searchInput?.addEventListener('input', function(e) {
            const query = e.target.value.trim();

            // Debounce: esperar 500ms después de la última tecla
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                if (query.length >= 2) {
                    searchFiles(query);
                } else if (query.length === 0) {
                    // Sin búsqueda, recargar contenido normal
                    isSearching = false;
                    loadContents(currentFolderId);
                }
            }, 500);
        });

        // Búsqueda en el servidor
        async function searchFiles(query) {
            try {
                isSearching = true;
                console.log(`🔍 Buscando en servidor: "${query}"`);

                // Mostrar indicador de carga
                const filesInfo = document.getElementById('filesInfo');
                filesInfo.textContent = 'Buscando...';

                // Buscar archivos en el servidor (la API soporta parámetro search)
                const response = await fetch(`/Files/SearchFiles?search=${encodeURIComponent(query)}&folderId=${currentFolderId || ''}`);

                if (!response.ok) {
                    throw new Error('Error en búsqueda');
                }

                const data = await response.json();

                // Mostrar resultados
                const folders = data.folders || [];
                const files = data.files?.files || data.files || [];

                // Guardar en cache
                currentFolders = folders;
                currentFiles = files;

                renderGrid(folders, files);
                renderList(folders, files);
                updateFilesInfo(folders.length, files.length, true);

                // Mostrar vistas
                if (currentViewMode === 'grid') {
                    document.getElementById('filesGrid').classList.remove('d-none');
                    document.getElementById('filesList').classList.add('d-none');
                } else {
                    document.getElementById('filesGrid').classList.add('d-none');
                    document.getElementById('filesList').classList.remove('d-none');
                }

                console.log(`✅ Resultados: ${folders.length} carpetas, ${files.length} archivos`);

            } catch (error) {
                console.error('❌ Error buscando:', error);
                const filesInfo = document.getElementById('filesInfo');
                filesInfo.textContent = 'Error en búsqueda';
            }
        }

        // Actualizar contador de archivos
        function updateFilesInfo(folderCount, fileCount, isFiltered = false) {
            const filesInfo = document.getElementById('filesInfo');
            const suffix = isFiltered ? ' (resultados de búsqueda)' : '';
            filesInfo.textContent = `${folderCount} carpeta(s), ${fileCount} archivo(s)${suffix}`;
        }

        // ================================================================
        // FILTROS RÁPIDOS
        // ================================================================
        document.querySelectorAll('.quick-filter').forEach(filter => {
            filter.addEventListener('click', function(e) {
                e.preventDefault();
                const filterType = this.dataset.filter;
                applyQuickFilter(filterType);
            });
        });

        async function applyQuickFilter(filterType) {
            try {
                console.log(`🎯 Aplicando filtro: ${filterType}`);
                const filesInfo = document.getElementById('filesInfo');
                filesInfo.textContent = 'Aplicando filtro...';

                let url = '/Files/GetContents?';

                switch (filterType) {
                    case 'recent':
                        url += 'orderBy=created_at&descending=true';
                        break;
                    case 'favorites':
                        url += 'isFavorite=true';
                        break;
                    case 'images':
                        url += 'extension=jpg,jpeg,png,gif,webp,svg';
                        break;
                    case 'documents':
                        url += 'extension=pdf,doc,docx,xls,xlsx,ppt,pptx,txt';
                        break;
                    case 'videos':
                        url += 'extension=mp4,avi,mov,mkv,webm';
                        break;
                    default:
                        loadContents(currentFolderId);
                        return;
                }

                const response = await fetch(url);
                if (!response.ok) throw new Error('Error aplicando filtro');

                const data = await response.json();
                const folders = data.folders || [];
                const files = data.files?.files || data.files || [];

                currentFolders = folders;
                currentFiles = files;

                renderGrid(folders, files);
                renderList(folders, files);

                const filterNames = {
                    'recent': 'Recientes',
                    'favorites': 'Favoritos',
                    'images': 'Imágenes',
                    'documents': 'Documentos',
                    'videos': 'Videos'
                };
                filesInfo.textContent = `Filtro: ${filterNames[filterType]} - ${files.length} archivo(s)`;

                // Mostrar vista actual
                if (currentViewMode === 'grid') {
                    document.getElementById('filesGrid').classList.remove('d-none');
                    document.getElementById('filesList').classList.add('d-none');
                } else {
                    document.getElementById('filesGrid').classList.add('d-none');
                    document.getElementById('filesList').classList.remove('d-none');
                }

            } catch (error) {
                console.error('❌ Error aplicando filtro:', error);
            }
        }

        // Upload modal - usar Bootstrap Modal API
        var uploadModalInstance = uploadModal ? new bootstrap.Modal(uploadModal) : null;
        var newFolderModalInstance = newFolderModal ? new bootstrap.Modal(newFolderModal) : null;

        document.getElementById('btnUpload')?.addEventListener('click', function(e) {
            e.preventDefault();
            if (uploadModalInstance) {
                uploadModalInstance.show();
            }
        });

        document.getElementById('btnUploadEmpty')?.addEventListener('click', function(e) {
            e.preventDefault();
            if (uploadModalInstance) {
                uploadModalInstance.show();
            }
        });

        // New folder modal
        document.getElementById('btnNewFolder')?.addEventListener('click', function(e) {
            e.preventDefault();
            if (newFolderModalInstance) {
                newFolderModalInstance.show();
            }
        });

        // File input - Seleccionar archivos
        document.getElementById('btnSelectFiles')?.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            document.getElementById('fileInput').click();
        });

        // Click en toda la zona de upload
        const dropZone = document.getElementById('dropZone');
        if (dropZone) {
            dropZone.addEventListener('click', function(e) {
                if (e.target.id !== 'btnSelectFiles') {
                    document.getElementById('fileInput').click();
                }
            });

            // Drag and drop
            dropZone.addEventListener('dragover', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.classList.add('dragover');
            });

            dropZone.addEventListener('dragleave', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.classList.remove('dragover');
            });

            dropZone.addEventListener('drop', function(e) {
                e.preventDefault();
                e.stopPropagation();
                this.classList.remove('dragover');

                const files = e.dataTransfer.files;
                if (files.length > 0) {
                    handleFiles(files);
                }
            });
        }

        // Manejar selección de archivos
        document.getElementById('fileInput')?.addEventListener('change', function(e) {
            if (this.files.length > 0) {
                handleFiles(this.files);
            }
        });

        // Función para manejar archivos seleccionados
        function handleFiles(files) {
            const uploadList = document.getElementById('uploadList');
            const btnStartUpload = document.getElementById('btnStartUpload');

            // ✅ GUARDAR archivos en variable global para el upload
            window.selectedFiles = Array.from(files);

            uploadList.innerHTML = '';

            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                const fileSize = formatFileSize(file.size);
                const fileIcon = getFileIcon(file.type);

                const fileItem = document.createElement('div');
                fileItem.className = 'd-flex align-items-center justify-content-between p-2 border border-secondary rounded mb-2';
                fileItem.dataset.index = i; // Guardar índice para poder eliminar
                fileItem.innerHTML = `
                    <div class="d-flex align-items-center">
                        <i class="bi ${fileIcon} me-2 text-info"></i>
                        <div>
                            <div class="text-light small">${file.name}</div>
                            <div class="text-muted small">${fileSize}</div>
                        </div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeFileFromList(${i}); this.parentElement.remove(); checkUploadButton();">
                        <i class="bi bi-x"></i>
                    </button>
                `;
                uploadList.appendChild(fileItem);
            }

            btnStartUpload.disabled = false;
        }

        // Función para eliminar archivo de la lista
        window.removeFileFromList = function(index) {
            window.selectedFiles.splice(index, 1);
        };

        // Función para formatear tamaño de archivo
        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

        // Función para obtener icono según tipo de archivo
        function getFileIcon(mimeType) {
            if (mimeType.startsWith('image/')) return 'bi-file-image';
            if (mimeType.startsWith('video/')) return 'bi-file-play';
            if (mimeType.startsWith('audio/')) return 'bi-file-music';
            if (mimeType.includes('pdf')) return 'bi-file-pdf';
            if (mimeType.includes('word') || mimeType.includes('document')) return 'bi-file-word';
            if (mimeType.includes('excel') || mimeType.includes('spreadsheet')) return 'bi-file-excel';
            if (mimeType.includes('zip') || mimeType.includes('compressed')) return 'bi-file-zip';
            return 'bi-file-earmark';
        }

        // Verificar si hay archivos para habilitar/deshabilitar botón
        window.checkUploadButton = function() {
            const btnStartUpload = document.getElementById('btnStartUpload');
            // ✅ Usar el array global en lugar de contar hijos del DOM
            btnStartUpload.disabled = window.selectedFiles.length === 0;
        };

        // Variable global para almacenar los archivos seleccionados (drag-drop o input)
        window.selectedFiles = [];

        // Botón SUBIR - Implementar subida de archivos
        document.getElementById('btnStartUpload')?.addEventListener('click', async function(e) {
            e.preventDefault();

            // Usar archivos del array global (funciona para drag-drop e input)
            const files = window.selectedFiles;

            if (!files || files.length === 0) {
                alert('Por favor selecciona al menos un archivo');
                return;
            }

            const btnStartUpload = this;
            const uploadProgress = document.getElementById('uploadProgress');
            const progressBar = uploadProgress.querySelector('.progress-bar');
            const uploadStatus = document.getElementById('uploadStatus');

            // Mostrar progreso
            uploadProgress.classList.remove('d-none');
            btnStartUpload.disabled = true;
            btnStartUpload.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Subiendo...';

            let uploaded = 0;
            let failed = 0;
            const total = files.length;

            // Obtener JWT de la sesión
            const apiBaseUrl = '@Html.Raw(ViewBag.ApiBaseUrl ?? "https://localhost:7001")';

            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                const formData = new FormData();
                formData.append('file', file);
                formData.append('title', file.name);
                // ✅ IMPORTANTE: Enviar folderId para que el archivo se guarde en la carpeta correcta
                if (currentFolderId) {
                    formData.append('folderId', currentFolderId);
                }

                uploadStatus.textContent = `Subiendo ${i + 1} de ${total}: ${file.name}`;

                try {
                    const response = await fetch('/Files/Upload', {
                        method: 'POST',
                        body: formData
                    });

                    if (response.ok) {
                        uploaded++;
                    } else {
                        const errorData = await response.json().catch(() => null);
                        console.error('Error subiendo archivo:', file.name, errorData);
                        failed++;
                    }
                } catch (error) {
                    console.error('Error subiendo archivo:', file.name, error);
                    failed++;
                }

                // Actualizar barra de progreso
                const percent = Math.round(((i + 1) / total) * 100);
                progressBar.style.width = percent + '%';
            }

            // Completado
            uploadStatus.textContent = `Completado: ${uploaded} subidos, ${failed} fallidos`;

            setTimeout(function() {
                // Cerrar modal y refrescar página
                if (uploadModalInstance) {
                    uploadModalInstance.hide();
                }

                // Limpiar estado
                uploadProgress.classList.add('d-none');
                progressBar.style.width = '0%';
                document.getElementById('uploadList').innerHTML = '';
                document.getElementById('fileInput').value = '';
                window.selectedFiles = []; // ✅ Limpiar array global
                btnStartUpload.disabled = true;
                btnStartUpload.innerHTML = '<i class="bi bi-upload me-2"></i>Subir';

                // Refrescar lista de archivos (sin recargar página)
                if (uploaded > 0) {
                    loadContents(currentFolderId);
                }
            }, 1500);
        });

        // View toggle
        document.getElementById('viewGrid')?.addEventListener('click', function() {
            currentViewMode = 'grid';
            this.classList.add('active');
            document.getElementById('viewList').classList.remove('active');
            document.getElementById('filesGrid').classList.remove('d-none');
            document.getElementById('filesList').classList.add('d-none');
        });

        document.getElementById('viewList')?.addEventListener('click', function() {
            currentViewMode = 'list';
            this.classList.add('active');
            document.getElementById('viewGrid').classList.remove('active');
            document.getElementById('filesList').classList.remove('d-none');
            document.getElementById('filesGrid').classList.add('d-none');
        });

        // ================================================================
        // CREAR CARPETA
        // ================================================================
        document.getElementById('btnCreateFolder')?.addEventListener('click', async function() {
            const folderName = document.getElementById('folderName').value.trim();
            const folderDescription = document.getElementById('folderDescription').value.trim();

            if (!folderName) {
                alert('Por favor ingresa un nombre para la carpeta');
                return;
            }

            const btnCreateFolder = this;
            btnCreateFolder.disabled = true;
            btnCreateFolder.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Creando...';

            try {
                const response = await fetch('/Files/CreateFolder', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        name: folderName,
                        description: folderDescription || null,
                        parentId: null // TODO: implementar navegación de carpetas
                    })
                });

                if (response.ok) {
                    const result = await response.json();
                    console.log('Carpeta creada:', result);

                    // Cerrar modal
                    const modal = bootstrap.Modal.getInstance(document.getElementById('newFolderModal'));
                    if (modal) modal.hide();

                    // Limpiar campos
                    document.getElementById('folderName').value = '';
                    document.getElementById('folderDescription').value = '';

                    // Mostrar mensaje de éxito y refrescar lista
                    alert('Carpeta creada exitosamente');
                    loadContents(currentFolderId);
                } else {
                    const error = await response.json();
                    console.error('Error creando carpeta:', error);
                    alert('Error al crear la carpeta: ' + (error.message || 'Error desconocido'));
                }
            } catch (error) {
                console.error('Error creando carpeta:', error);
                alert('Error de conexión al crear la carpeta');
            } finally {
                btnCreateFolder.disabled = false;
                btnCreateFolder.innerHTML = '<i class="bi bi-folder-plus me-2"></i>Crear Carpeta';
            }
        });
    });
</script>
}
