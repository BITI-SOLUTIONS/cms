@* ================================================================================ *@
@* ARCHIVO: CMS.UI/Views/Inventory/LabelItems.cshtml                               *@
@* PROPÓSITO: Vista de impresión de etiquetas de artículos                         *@
@* DESCRIPCIÓN: Permite buscar artículos de etiqueta, editar los datos de la       *@
@*              etiqueta (label_item, label_price, label_item_barcode) e imprimir  *@
@* AUTOR: EAMR, BITI SOLUTIONS S.A                                                 *@
@* CREADO: 2026-02-20                                                              *@
@* ================================================================================ *@

@model CMS.UI.Controllers.LabelItemsViewModel

@{
    ViewData["Title"] = "Etiquetas de Artículos";
}

<div class="content-container">
    <div class="page-header mb-4">
        <div class="page-header-content">
            <h1 class="text-white">
                <i class="bi bi-printer me-2"></i>
                Etiquetas de Artículos
            </h1>
            <p style="color: #94a3b8;" class="mb-0">Seleccione un artículo para imprimir su etiqueta</p>
        </div>
        @if (Model.ReturnToItemId.HasValue)
        {
            <div class="page-header-actions">
                <a asp-controller="Inventory" asp-action="ItemDetails" asp-route-id="@Model.ReturnToItemId" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Volver al Artículo
                </a>
            </div>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success-tech d-flex align-items-center mb-4">
            <i class="bi bi-check-circle-fill me-2"></i>
            <div>@TempData["Success"]</div>
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger-tech d-flex align-items-center mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div>@TempData["Error"]</div>
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-5">
            <div class="card border-0 h-100" style="background: linear-gradient(135deg, #1a1f36 0%, #252b47 100%);">
                <div class="card-header" style="background: rgba(0, 0, 0, 0.2); border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
                    <h5 class="mb-0 text-white">
                        <i class="bi bi-search me-2"></i>Buscar Artículos
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="LabelItems" method="get" class="mb-3">
                        <div class="input-group">
                            <input type="text" name="search" class="form-control" 
                                   placeholder="Buscar por código, nombre, precio..."
                                   value="@Model.Search"
                                   style="background-color: #1e293b; color: #f0f0f0; border-color: #06b6d4;">
                            <button type="submit" class="btn btn-outline-info">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <div class="item-list" style="max-height: 400px; overflow-y: auto;">
                        @if (Model.Items.Any())
                        {
                            @foreach (var item in Model.Items)
                            {
                                <div class="item-row p-3 mb-2 rounded" 
                                     data-item-id="@item.Id"
                                     data-item-code="@item.Code"
                                     data-item-name="@item.Name"
                                     data-item-label="@(item.LabelItem ?? item.Name)"
                                     data-item-price="@item.LabelPrice"
                                     data-item-barcode="@(item.LabelItemBarcode ?? item.Barcode)"
                                     data-print-name="@item.PrintLabelName.ToString().ToLower()"
                                     data-print-price="@item.PrintLabelPrice.ToString().ToLower()"
                                     data-print-barcode="@item.PrintLabelBarcode.ToString().ToLower()"
                                     data-label-width="@item.LabelWidthCm"
                                     data-label-height="@item.LabelHeightCm"
                                     data-label-orientation="@item.LabelOrientation"
                                     data-print-border="@item.PrintLabelBorder.ToString().ToLower()"
                                     data-border-color="@item.LabelBorderColor"
                                     data-name-color="@item.LabelNameColor"
                                     data-price-color="@item.LabelPriceColor"
                                     data-barcode-color="@item.LabelBarcodeColor"
                                     data-font-size="@item.LabelFontSize"
                                     data-font-family="@item.LabelFontFamily"
                                     data-price-decimals="@item.LabelPriceDecimals"
                                     data-thousand-separator="@item.LabelThousandSeparator"
                                     data-currency-symbol="@item.LabelCurrencySymbol"
                                     data-print-currency="@item.PrintCurrencySymbol.ToString().ToLower()"
                                     onclick="selectItem(this)"
                                     style="background: rgba(0,0,0,0.2); cursor: pointer; transition: all 0.2s;">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <code class="text-info">@item.Code</code>
                                            <div class="fw-semibold text-white">@item.Name</div>
                                            @if (!string.IsNullOrEmpty(item.LabelItem))
                                            {
                                                <small class="text-success">
                                                    <i class="bi bi-tag me-1"></i>@item.LabelItem
                                                </small>
                                            }
                                        </div>
                                        <span class="badge bg-success fs-6">
                                            ₡@item.LabelPrice.ToString("N2")
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="bi bi-inbox display-4 text-secondary"></i>
                                <p class="text-white mt-2">No hay artículos de etiqueta</p>
                            </div>
                        }
                    </div>

                    @if (Model.TotalPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" href="?page=@i&search=@Model.Search" 
                                           style="background-color: @(i == Model.CurrentPage ? "#06b6d4" : "#1e293b"); border-color: #06b6d4; color: white;">@i</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card border-0 h-100" style="background: linear-gradient(135deg, #1a1f36 0%, #252b47 100%);">
                <div class="card-header d-flex justify-content-between align-items-center" style="background: rgba(0, 0, 0, 0.2); border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
                    <h5 class="mb-0 text-white">
                        <i class="bi bi-tag me-2"></i>Datos de la Etiqueta
                    </h5>
                </div>
                <div class="card-body">
                    <div id="noItemSelected" class="text-center py-5">
                        <i class="bi bi-hand-index display-1 text-secondary"></i>
                        <h5 class="text-white mt-3">Seleccione un artículo</h5>
                        <p style="color: #94a3b8;">Haga clic en un artículo de la lista para ver y editar su etiqueta</p>
                    </div>

                    <div id="labelForm" style="display: none;">
                        <input type="hidden" id="selectedItemId" />

                        <!-- Código y Nombre Original -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label" style="color: #22d3ee;">Código</label>
                                <div class="fs-5" id="itemCode" style="color: #22d3ee;">-</div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" style="color: #22d3ee;">Nombre Original</label>
                                <div class="fs-5 text-white" id="itemName">-</div>
                            </div>
                        </div>

                        <!-- 1. Botón Imprimir Etiqueta - PRIMERO, GRANDE Y ANCHO COMPLETO -->
                        <div class="mb-4">
                            <button type="button" class="btn btn-success btn-lg py-3 fs-4 w-100" id="btnPrint" disabled onclick="printLabel()">
                                <i class="bi bi-printer-fill me-2 fs-3"></i>Imprimir Etiqueta
                            </button>
                        </div>

                        <!-- 2. Precio de Etiqueta - DESTACADO Y GRANDE -->
                        <div class="mb-4 p-4 rounded" style="background: linear-gradient(135deg, rgba(34, 197, 94, 0.1) 0%, rgba(22, 163, 74, 0.2) 100%); border: 2px solid rgba(34, 197, 94, 0.3);">
                            <label class="form-label text-white fs-5 mb-3">
                                <i class="bi bi-currency-dollar me-2 text-success fs-4" id="priceLabelIcon"></i><span id="priceLabelText">Precio de Etiqueta</span>
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text fs-3 px-4" id="priceInputSymbol" style="background-color: #16a34a; border-color: #16a34a; color: white;">₡</span>
                                <input type="number" id="labelPrice" class="form-control form-control-lg fs-2 text-center fw-bold" step="0.01" min="0"
                                       placeholder="0.00"
                                       style="background-color: #1e293b; color: #22c55e; border-color: #16a34a; height: 80px;">
                            </div>
                        </div>

                        <!-- 3. Vista Previa de Etiqueta -->
                        <div class="mb-4 p-4 rounded" style="background: white; color: black;">
                            <h6 class="text-muted mb-3">
                                <i class="bi bi-eye me-2"></i>Vista Previa de Etiqueta:
                            </h6>
                            <div class="d-flex justify-content-center">
                                <div class="text-center p-3" id="labelPreview" style="min-height: 75px; border: 2px solid #000000;">
                                    <div id="previewName" class="fw-bold" style="font-size: 14px;">Nombre del Producto</div>
                                    <div id="previewPrice" class="fw-bold" style="font-size: 20px; color: #16a34a;">₡0.00</div>
                                    <div id="previewBarcode" class="font-monospace" style="font-size: 10px;">||||||||||||||||</div>
                                </div>
                            </div>
                        </div>

                        <hr style="border-color: rgba(255,255,255,0.2);" class="my-4" />

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label text-white">
                                    <i class="bi bi-fonts me-1 text-info"></i>Texto de Etiqueta
                                </label>
                                <input type="text" id="labelItem" class="form-control form-control-lg"
                                       placeholder="Nombre que aparecerá en la etiqueta"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                <small style="color: #94a3b8;">Este texto se imprimirá como nombre del producto</small>
                            </div>

                            <div class="col-12">
                                <label class="form-label text-white">
                                    <i class="bi bi-upc me-1 text-warning"></i>Código de Barras
                                </label>
                                <input type="text" id="labelBarcode" class="form-control form-control-lg"
                                       placeholder="Código de barras para la etiqueta"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                            </div>

                            <!-- Checkboxes de impresión -->
                            <div class="col-12">
                                <hr style="border-color: rgba(255,255,255,0.2);" class="my-2" />
                                <label class="form-label text-white mb-3">
                                    <i class="bi bi-printer me-1 text-info"></i>Opciones de Impresión
                                </label>
                                <div class="d-flex flex-wrap gap-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="printLabelPrice" checked>
                                        <label class="form-check-label text-white" for="printLabelPrice">
                                            <i class="bi bi-currency-dollar me-1"></i>Imprimir Precio
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="printCurrencySymbol" checked>
                                        <label class="form-check-label text-white" for="printCurrencySymbol">
                                            <i class="bi bi-cash me-1"></i>Mostrar Símbolo Moneda
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="printLabelName" checked>
                                        <label class="form-check-label text-white" for="printLabelName">
                                            <i class="bi bi-fonts me-1"></i>Imprimir Nombre
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="printLabelBarcode" checked>
                                        <label class="form-check-label text-white" for="printLabelBarcode">
                                            <i class="bi bi-upc me-1"></i>Imprimir Código de Barras
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="printLabelBorder" checked>
                                        <label class="form-check-label text-white" for="printLabelBorder">
                                            <i class="bi bi-square me-1"></i>Imprimir Recuadro
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Tamaño de la etiqueta -->
                            <div class="col-12">
                                <hr style="border-color: rgba(255,255,255,0.2);" class="my-2" />
                                <label class="form-label text-white mb-3">
                                    <i class="bi bi-rulers me-1 text-info"></i>Tamaño de Etiqueta
                                </label>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label text-white small">Ancho (cm)</label>
                                        <input type="number" id="labelWidthCm" class="form-control" step="0.1" min="1" max="20" value="4"
                                               style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label text-white small">Alto (cm)</label>
                                        <input type="number" id="labelHeightCm" class="form-control" step="0.1" min="1" max="20" value="2"
                                               style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label text-white small">Orientación</label>
                                        <select id="labelOrientation" class="form-select"
                                                style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                            <option value="horizontal">Horizontal</option>
                                            <option value="vertical">Vertical</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Colores de impresión -->
                            <div class="col-12">
                                <hr style="border-color: rgba(255,255,255,0.2);" class="my-2" />
                                <label class="form-label text-white mb-3">
                                    <i class="bi bi-palette me-1 text-info"></i>Colores de Impresión
                                </label>
                                <div class="row g-3">
                                    <div class="col-md-6 col-lg-3">
                                        <label class="form-label text-white small">Color del Recuadro</label>
                                        <div class="input-group">
                                            <input type="color" id="labelBorderColor" class="form-control form-control-color" value="#000000">
                                            <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelBorderColor', '#000000')"><span class="color-dot" style="background:#000000"></span> Negro</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelBorderColor', '#ff0000')"><span class="color-dot" style="background:#ff0000"></span> Rojo</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelBorderColor', '#ffff00')"><span class="color-dot" style="background:#ffff00"></span> Amarillo</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelBorderColor', '#ffffff')"><span class="color-dot" style="background:#ffffff;border:1px solid #ccc"></span> Blanco</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-lg-3">
                                        <label class="form-label text-white small">Color del Nombre</label>
                                        <div class="input-group">
                                            <input type="color" id="labelNameColor" class="form-control form-control-color" value="#000000">
                                            <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelNameColor', '#000000')"><span class="color-dot" style="background:#000000"></span> Negro</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelNameColor', '#ff0000')"><span class="color-dot" style="background:#ff0000"></span> Rojo</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelNameColor', '#ffff00')"><span class="color-dot" style="background:#ffff00"></span> Amarillo</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelNameColor', '#ffffff')"><span class="color-dot" style="background:#ffffff;border:1px solid #ccc"></span> Blanco</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-lg-3">
                                        <label class="form-label text-white small">Color del Precio</label>
                                        <div class="input-group">
                                            <input type="color" id="labelPriceColor" class="form-control form-control-color" value="#16a34a">
                                            <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelPriceColor', '#000000')"><span class="color-dot" style="background:#000000"></span> Negro</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelPriceColor', '#ff0000')"><span class="color-dot" style="background:#ff0000"></span> Rojo</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelPriceColor', '#ffff00')"><span class="color-dot" style="background:#ffff00"></span> Amarillo</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelPriceColor', '#ffffff')"><span class="color-dot" style="background:#ffffff;border:1px solid #ccc"></span> Blanco</a></li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelPriceColor', '#16a34a')"><span class="color-dot" style="background:#16a34a"></span> Verde (default)</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-lg-3">
                                        <label class="form-label text-white small">Color del Código</label>
                                        <div class="input-group">
                                            <input type="color" id="labelBarcodeColor" class="form-control form-control-color" value="#000000">
                                            <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelBarcodeColor', '#000000')"><span class="color-dot" style="background:#000000"></span> Negro</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelBarcodeColor', '#ff0000')"><span class="color-dot" style="background:#ff0000"></span> Rojo</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelBarcodeColor', '#ffff00')"><span class="color-dot" style="background:#ffff00"></span> Amarillo</a></li>
                                                <li><a class="dropdown-item" href="#" onclick="resetColor('labelBarcodeColor', '#ffffff')"><span class="color-dot" style="background:#ffffff;border:1px solid #ccc"></span> Blanco</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Formato de texto y precio -->
                            <div class="col-12">
                                <hr style="border-color: rgba(255,255,255,0.2);" class="my-2" />
                                <label class="form-label text-white mb-3">
                                    <i class="bi bi-type me-1 text-info"></i>Formato de Texto y Precio
                                </label>
                                <div class="row g-3">
                                    <!-- Primera fila: Tamaño Fuente y Tipo de Letra -->
                                    <div class="col-6">
                                        <label class="form-label text-white small">Tamaño Fuente</label>
                                        <div class="input-group">
                                            <input type="number" id="labelFontSize" class="form-control" step="0.5" min="6" max="72" value="14"
                                                   style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                            <span class="input-group-text" style="background-color: #334155; border-color: rgba(6, 182, 212, 0.5); color: #94a3b8;">pt</span>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label text-white small">Tipo de Letra</label>
                                        <select id="labelFontFamily" class="form-select"
                                                style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                            <option value="Arial">Arial</option>
                                            <option value="Helvetica">Helvetica</option>
                                            <option value="Times New Roman">Times New Roman</option>
                                            <option value="Georgia">Georgia</option>
                                            <option value="Verdana">Verdana</option>
                                            <option value="Tahoma">Tahoma</option>
                                            <option value="Courier New">Courier New</option>
                                            <option value="Impact">Impact</option>
                                        </select>
                                    </div>

                                    <!-- Segunda fila: Decimales y Sep. Miles -->
                                    <div class="col-6">
                                        <label class="form-label text-white small">Cantidad de Decimales</label>
                                        <select id="labelPriceDecimals" class="form-select"
                                                style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                            <option value="0">0 decimales</option>
                                            <option value="1">1 decimal</option>
                                            <option value="2" selected>2 decimales</option>
                                            <option value="3">3 decimales</option>
                                            <option value="4">4 decimales</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label text-white small">Separador de Miles</label>
                                        <select id="labelThousandSeparator" class="form-select"
                                                style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                            <option value=",">, (coma)</option>
                                            <option value=".">. (punto)</option>
                                        </select>
                                    </div>

                                    <!-- Tercera fila: Moneda -->
                                    <div class="col-6">
                                        <label class="form-label text-white small">Símbolo de Moneda</label>
                                        <select id="labelCurrencySymbol" class="form-select"
                                                style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                            <option value="₡">₡ Colones (Costa Rica)</option>
                                            <option value="$">$ Dólares (USD)</option>
                                            <option value="€">€ Euros (EUR)</option>
                                        </select>
                                    </div>
                                </div>
                                <small class="text-muted mt-2 d-block" style="color: #64748b !important;">
                                    <i class="bi bi-info-circle me-1"></i>El separador de decimales es el contrario al separador de miles seleccionado.
                                </small>
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="button" class="btn btn-tech-primary btn-lg flex-grow-1" onclick="saveLabel()">
                                <i class="bi bi-check-lg me-2"></i>Guardar Cambios
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-lg" onclick="resetLabel()">
                                <i class="bi bi-arrow-counterclockwise me-2"></i>Restaurar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

