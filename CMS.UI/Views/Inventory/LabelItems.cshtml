@section Scripts {
    <script src="~/js/label-items.js?v=@DateTime.UtcNow.Ticks"></script>
    @if (Model.SelectedItemId.HasValue)
    {
        <script>
            // Preseleccionar el artículo cuando viene desde ItemDetails
            // Usar setTimeout para asegurar que label-items.js esté completamente cargado
            (function() {
                function preselectItem() {
                    console.log('LabelItems: Attempting to preselect item...');

                    // Verificar que selectItem esté disponible
                    if (typeof selectItem !== 'function') {
                        console.log('LabelItems: selectItem not available yet, retrying in 200ms...');
                        setTimeout(preselectItem, 200);
                        return;
                    }

                    const itemId = @Model.SelectedItemId.Value;
                    console.log('LabelItems: Preselecting item ID:', itemId);

                    const itemRow = document.querySelector('[data-item-id="' + itemId + '"]');
                    if (itemRow) {
                        console.log('LabelItems: Item found in list, clicking...');
                        itemRow.click();
                        itemRow.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    } else {
                        console.log('LabelItems: Item not in list, loading via AJAX...');
                        loadItemViaAjax(itemId);
                    }
                }

                function loadItemViaAjax(itemId) {
                    fetch('/Inventory/LabelItems/GetItem/' + itemId)
                        .then(function(response) {
                            console.log('LabelItems: AJAX response status:', response.status);
                            if (!response.ok) {
                                throw new Error('HTTP error! status: ' + response.status);
                            }
                            return response.json();
                        })
                        .then(function(data) {
                            console.log('LabelItems: AJAX response:', data);

                            // Handle both camelCase and PascalCase responses
                            var item = data.item || data.Item;
                            var success = data.success || data.Success;

                            console.log('LabelItems: success=', success, 'item=', item);

                            if (success && item) {
                                console.log('LabelItems: Processing item:', item.id || item.Id);

                                // Helper to get property with fallback
                                var getProp = function(obj, camel, pascal, def) {
                                    var v = obj[camel];
                                    if (v === undefined) v = obj[pascal];
                                    return (v !== undefined && v !== null) ? v : def;
                                };

                                // Crear un elemento virtual para simular el clic
                                var virtualItem = {
                                    dataset: {
                                        itemId: String(getProp(item, 'id', 'Id', 0)),
                                        itemCode: String(getProp(item, 'code', 'Code', '')),
                                        itemName: String(getProp(item, 'name', 'Name', '')),
                                        itemLabel: String(getProp(item, 'labelItem', 'LabelItem', '') || getProp(item, 'name', 'Name', '')),
                                        itemPrice: String(getProp(item, 'labelPrice', 'LabelPrice', 0)),
                                        itemBarcode: String(getProp(item, 'labelItemBarcode', 'LabelItemBarcode', '') || getProp(item, 'barcode', 'Barcode', '')),
                                        printName: String(getProp(item, 'printLabelName', 'PrintLabelName', true)).toLowerCase(),
                                        printPrice: String(getProp(item, 'printLabelPrice', 'PrintLabelPrice', true)).toLowerCase(),
                                        printBarcode: String(getProp(item, 'printLabelBarcode', 'PrintLabelBarcode', true)).toLowerCase(),
                                        labelWidth: String(getProp(item, 'labelWidthCm', 'LabelWidthCm', 4)),
                                        labelHeight: String(getProp(item, 'labelHeightCm', 'LabelHeightCm', 2)),
                                        labelOrientation: String(getProp(item, 'labelOrientation', 'LabelOrientation', 'horizontal')),
                                        printBorder: String(getProp(item, 'printLabelBorder', 'PrintLabelBorder', true)).toLowerCase(),
                                        borderColor: String(getProp(item, 'labelBorderColor', 'LabelBorderColor', '#000000')),
                                        nameColor: String(getProp(item, 'labelNameColor', 'LabelNameColor', '#000000')),
                                        priceColor: String(getProp(item, 'labelPriceColor', 'LabelPriceColor', '#16a34a')),
                                        barcodeColor: String(getProp(item, 'labelBarcodeColor', 'LabelBarcodeColor', '#000000')),
                                        fontSize: String(getProp(item, 'labelFontSize', 'LabelFontSize', 14)),
                                        fontFamily: String(getProp(item, 'labelFontFamily', 'LabelFontFamily', 'Arial')),
                                        priceDecimals: String(getProp(item, 'labelPriceDecimals', 'LabelPriceDecimals', 2)),
                                        thousandSeparator: String(getProp(item, 'labelThousandSeparator', 'LabelThousandSeparator', ',')),
                                        currencySymbol: String(getProp(item, 'labelCurrencySymbol', 'LabelCurrencySymbol', '₡')),
                                        printCurrency: String(getProp(item, 'printCurrencySymbol', 'PrintCurrencySymbol', true)).toLowerCase()
                                    }
                                };

                                console.log('LabelItems: Virtual item dataset:', JSON.stringify(virtualItem.dataset));
                                console.log('LabelItems: Calling selectItem...');

                                try {
                                    selectItem(virtualItem);
                                    console.log('LabelItems: selectItem completed successfully');
                                } catch (e) {
                                    console.error('LabelItems: Error in selectItem:', e);
                                }
                            } else {
                                console.error('LabelItems: Invalid response - success:', success, 'item:', item);
                            }
                        })
                        .catch(function(err) {
                            console.error('LabelItems: Error loading item:', err);
                        });
                }

                // Iniciar después de que la página haya cargado completamente
                if (document.readyState === 'complete') {
                    setTimeout(preselectItem, 100);
                } else {
                    window.addEventListener('load', function() {
                        setTimeout(preselectItem, 100);
                    });
                }
            })();
        </script>
    }
}
