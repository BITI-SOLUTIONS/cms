@* ================================================================================ *@
@* ARCHIVO: CMS.UI/Views/Inventory/CreateItem.cshtml                               *@
@* PROPÓSITO: Formulario para crear un nuevo artículo                              *@
@* AUTOR: EAMR, BITI SOLUTIONS S.A                                                 *@
@* CREADO: 2026-02-27                                                              *@
@* ================================================================================ *@

@model CMS.UI.Controllers.CreateItemViewModel

@{
    ViewData["Title"] = "Nuevo Artículo";
}

<div class="content-container">
    <!-- ===== HEADER ===== -->
    <div class="page-header mb-4">
        <div class="page-header-content">
            <h1 class="text-white">
                <i class="bi bi-plus-circle me-2"></i>
                Nuevo Artículo
            </h1>
            <p style="color: #94a3b8;" class="mb-0">Complete la información del artículo</p>
        </div>
        <div class="page-header-actions">
            <a asp-action="Items" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Volver
            </a>
        </div>
    </div>

    <!-- ===== ALERTAS ===== -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger-tech d-flex align-items-center mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div>@TempData["Error"]</div>
            <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="CreateItem" method="post">
        @Html.AntiForgeryToken()

        <div class="row">
            <!-- ===== INFORMACIÓN BÁSICA ===== -->
            <div class="col-md-8">
                <div class="card border-0 mb-4" style="background: linear-gradient(135deg, #1a1f36 0%, #252b47 100%);">
                    <div class="card-header" style="background: rgba(0, 0, 0, 0.2); border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
                        <h5 class="mb-0 text-white">
                            <i class="bi bi-info-circle me-2 text-info"></i>Información Básica
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-upc me-1 text-warning"></i>Código <span class="text-danger">*</span>
                                </label>
                                <input type="text" asp-for="Code" class="form-control" required
                                       placeholder="SKU001"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>
                            <div class="col-md-8">
                                <label class="form-label text-white">
                                    <i class="bi bi-fonts me-1 text-info"></i>Nombre <span class="text-danger">*</span>
                                </label>
                                <input type="text" asp-for="Name" class="form-control" required
                                       placeholder="Nombre del artículo"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label text-white">
                                    <i class="bi bi-text-paragraph me-1"></i>Descripción
                                </label>
                                <textarea asp-for="Description" class="form-control" rows="3"
                                          placeholder="Descripción detallada del artículo"
                                          style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);"></textarea>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-upc-scan me-1"></i>Código de Barras
                                </label>
                                <input type="text" asp-for="Barcode" class="form-control"
                                       placeholder="7501234567890"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-building me-1"></i>Marca
                                </label>
                                <input type="text" asp-for="Brand" class="form-control"
                                       placeholder="Samsung"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-rulers me-1"></i>Unidad de Medida
                                </label>
                                <select asp-for="IdUnitOfMeasure" class="form-select"
                                        style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                    <option value="">-- Seleccione --</option>
                                    @foreach (var unit in Model.UnitsOfMeasure)
                                    {
                                        <option value="@unit.Id" selected="@(Model.IdUnitOfMeasure == unit.Id)">@unit.Name (@unit.Symbol)</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== CLASIFICACIONES ===== -->
                <div class="card border-0 mb-4" style="background: linear-gradient(135deg, #1a1f36 0%, #252b47 100%);">
                    <div class="card-header" style="background: rgba(0, 0, 0, 0.2); border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
                        <h5 class="mb-0 text-white">
                            <i class="bi bi-tags me-2 text-warning"></i>Clasificaciones
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-1-circle me-1"></i>Clasificación 1 (Categoría)
                                </label>
                                <select asp-for="IdClassification1" class="form-select"
                                        style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                    <option value="">-- Seleccione --</option>
                                    @foreach (var c in Model.Classifications1)
                                    {
                                        <option value="@c.Id" selected="@(Model.IdClassification1 == c.Id)">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-2-circle me-1"></i>Clasificación 2 (Subcategoría)
                                </label>
                                <select asp-for="IdClassification2" class="form-select"
                                        style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                    <option value="">-- Seleccione --</option>
                                    @foreach (var c in Model.Classifications2)
                                    {
                                        <option value="@c.Id" selected="@(Model.IdClassification2 == c.Id)">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-3-circle me-1"></i>Clasificación 3 (Familia)
                                </label>
                                <select asp-for="IdClassification3" class="form-select"
                                        style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                    <option value="">-- Seleccione --</option>
                                    @foreach (var c in Model.Classifications3)
                                    {
                                        <option value="@c.Id" selected="@(Model.IdClassification3 == c.Id)">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-4-circle me-1"></i>Clasificación 4 (Grupo)
                                </label>
                                <select asp-for="IdClassification4" class="form-select"
                                        style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                    <option value="">-- Seleccione --</option>
                                    @foreach (var c in Model.Classifications4)
                                    {
                                        <option value="@c.Id" selected="@(Model.IdClassification4 == c.Id)">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-5-circle me-1"></i>Clasificación 5 (Línea)
                                </label>
                                <select asp-for="IdClassification5" class="form-select"
                                        style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                    <option value="">-- Seleccione --</option>
                                    @foreach (var c in Model.Classifications5)
                                    {
                                        <option value="@c.Id" selected="@(Model.IdClassification5 == c.Id)">@c.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-6-circle me-1"></i>Clasificación 6 (Tipo)
                                </label>
                                <select asp-for="IdClassification6" class="form-select"
                                        style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                    <option value="">-- Seleccione --</option>
                                    @foreach (var c in Model.Classifications6)
                                    {
                                        <option value="@c.Id" selected="@(Model.IdClassification6 == c.Id)">@c.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== PRECIOS ===== -->
                <div class="card border-0 mb-4" style="background: linear-gradient(135deg, #1a1f36 0%, #252b47 100%);">
                    <div class="card-header" style="background: rgba(0, 0, 0, 0.2); border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
                        <h5 class="mb-0 text-white">
                            <i class="bi bi-currency-dollar me-2 text-success"></i>Precios
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-tag me-1"></i>Precio de Costo
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background-color: #334155; border-color: rgba(6, 182, 212, 0.5); color: #06b6d4;">₡</span>
                                    <input type="number" asp-for="CostPrice" class="form-control" step="0.01" min="0"
                                           placeholder="0.00"
                                           style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-tags me-1 text-success"></i>Precio de Venta
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background-color: #334155; border-color: rgba(6, 182, 212, 0.5); color: #06b6d4;">₡</span>
                                    <input type="number" asp-for="SalePrice" class="form-control" step="0.01" min="0"
                                           placeholder="0.00"
                                           style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-percent me-1 text-warning"></i>Tasa de Impuesto (%)
                                </label>
                                <div class="input-group">
                                    <input type="number" asp-for="TaxRate" class="form-control" step="0.01" min="0" max="100"
                                           placeholder="13.00"
                                           style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                    <span class="input-group-text" style="background-color: #334155; border-color: rgba(6, 182, 212, 0.5); color: #06b6d4;">%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== STOCK ===== -->
                <div class="card border-0 mb-4" style="background: linear-gradient(135deg, #1a1f36 0%, #252b47 100%);">
                    <div class="card-header" style="background: rgba(0, 0, 0, 0.2); border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
                        <h5 class="mb-0 text-white">
                            <i class="bi bi-box-seam me-2 text-warning"></i>Stock
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-arrow-down me-1 text-danger"></i>Stock Mínimo
                                </label>
                                <input type="number" asp-for="MinStock" class="form-control" step="0.01" min="0"
                                       placeholder="0"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-arrow-up me-1 text-success"></i>Stock Máximo
                                </label>
                                <input type="number" asp-for="MaxStock" class="form-control" step="0.01" min="0"
                                       placeholder="0"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-white">
                                    <i class="bi bi-box me-1 text-info"></i>Stock Actual
                                </label>
                                <input type="number" asp-for="CurrentStock" class="form-control" step="0.01" min="0"
                                       placeholder="0"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== CONFIGURACIÓN Y ETIQUETA ===== -->
            <div class="col-md-4">
                <!-- Configuración -->
                <div class="card border-0 mb-4" style="background: linear-gradient(135deg, #1a1f36 0%, #252b47 100%);">
                    <div class="card-header" style="background: rgba(0, 0, 0, 0.2); border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
                        <h5 class="mb-0 text-white">
                            <i class="bi bi-gear me-2"></i>Configuración
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                            <label class="form-check-label text-white" asp-for="IsActive">
                                <i class="bi bi-check-circle me-1 text-success"></i>Activo
                            </label>
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="IsSellable" checked>
                            <label class="form-check-label text-white" asp-for="IsSellable">
                                <i class="bi bi-cart me-1 text-info"></i>Vendible
                            </label>
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="IsPurchasable" checked>
                            <label class="form-check-label text-white" asp-for="IsPurchasable">
                                <i class="bi bi-bag me-1 text-warning"></i>Comprable
                            </label>
                        </div>
                        <hr style="border-color: rgba(255,255,255,0.2);">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="TrackLots">
                            <label class="form-check-label text-white" asp-for="TrackLots">
                                <i class="bi bi-layers me-1"></i>Manejo de Lotes
                            </label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="TrackSerialNumbers">
                            <label class="form-check-label text-white" asp-for="TrackSerialNumbers">
                                <i class="bi bi-123 me-1"></i>Números de Serie
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Etiqueta -->
                <div class="card border-0 mb-4" style="background: linear-gradient(135deg, #1a1f36 0%, #252b47 100%);">
                    <div class="card-header" style="background: rgba(0, 0, 0, 0.2); border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
                        <h5 class="mb-0 text-white">
                            <i class="bi bi-tag me-2 text-success"></i>Configuración de Etiqueta
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="IsLabelItem" id="isLabelItem">
                            <label class="form-check-label text-white" asp-for="IsLabelItem">
                                <i class="bi bi-printer me-1 text-success"></i>Es Artículo de Etiqueta
                            </label>
                        </div>
                        <div id="labelFields">
                            <div class="mb-3">
                                <label class="form-label text-white small">Texto de Etiqueta</label>
                                <input type="text" asp-for="LabelItem" class="form-control"
                                       placeholder="Texto para la etiqueta"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-white small">Precio de Etiqueta</label>
                                <div class="input-group">
                                    <span class="input-group-text" style="background-color: #334155; border-color: rgba(6, 182, 212, 0.5); color: #06b6d4;">₡</span>
                                    <input type="number" asp-for="LabelPrice" class="form-control" step="0.01" min="0"
                                           placeholder="0.00"
                                           style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-white small">Código de Barras de Etiqueta</label>
                                <input type="text" asp-for="LabelItemBarcode" class="form-control"
                                       placeholder="Código de barras"
                                       style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                            </div>
                            <hr style="border-color: rgba(255,255,255,0.2);">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" asp-for="PrintLabelName" checked>
                                <label class="form-check-label text-white small" asp-for="PrintLabelName">Imprimir Nombre</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" asp-for="PrintLabelPrice" checked>
                                <label class="form-check-label text-white small" asp-for="PrintLabelPrice">Imprimir Precio</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" asp-for="PrintLabelBarcode" checked>
                                <label class="form-check-label text-white small" asp-for="PrintLabelBarcode">Imprimir Código de Barras</label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Imagen -->
                <div class="card border-0 mb-4" style="background: linear-gradient(135deg, #1a1f36 0%, #252b47 100%);">
                    <div class="card-header" style="background: rgba(0, 0, 0, 0.2); border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
                        <h5 class="mb-0 text-white">
                            <i class="bi bi-image me-2"></i>Imagen
                        </h5>
                    </div>
                    <div class="card-body">
                        <label class="form-label text-white small">URL de la Imagen</label>
                        <input type="url" asp-for="ImageUrl" class="form-control"
                               placeholder="https://ejemplo.com/imagen.jpg"
                               style="background-color: #1e293b; color: #f0f0f0; border-color: rgba(6, 182, 212, 0.5);">
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== BOTONES ===== -->
        <div class="d-flex gap-3 mt-4">
            <button type="submit" class="btn btn-success btn-lg px-5">
                <i class="bi bi-check-lg me-2"></i>Guardar Artículo
            </button>
            <a asp-action="Items" class="btn btn-outline-secondary btn-lg px-4">
                <i class="bi bi-x-lg me-2"></i>Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const isLabelItem = document.getElementById('isLabelItem');
            const labelFields = document.getElementById('labelFields');

            function toggleLabelFields() {
                labelFields.style.display = isLabelItem.checked ? 'block' : 'none';
            }

            isLabelItem.addEventListener('change', toggleLabelFields);
            toggleLabelFields();
        });
    </script>
}
