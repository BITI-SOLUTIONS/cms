@* ================================================================================
    ARCHIVO: CMS.UI/Views/Account/ChangePassword.cshtml
    PROPÓSITO: Formulario para cambiar contraseña del usuario autenticado
    DESCRIPCIÓN: Permite al usuario cambiar su contraseña actual
    AUTOR: EAMR, BITI SOLUTIONS S.A
    CREADO: 2026-03-04
    ⚠️ TEMA OSCURO: Usar text-light, text-white para textos principales
   ================================================================================ *@

@model CMS.UI.Models.Auth.ChangePasswordViewModel
@{
    ViewData["Title"] = "Cambiar Contraseña";
    Layout = "_Layout";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            @* Header *@
            <div class="d-flex align-items-center mb-4">
                <a href="@Url.Action("Profile", "Home")" class="btn btn-outline-secondary me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div class="rounded-circle bg-gradient d-flex align-items-center justify-content-center me-3"
                     style="width: 60px; height: 60px; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                    <i class="bi bi-key-fill text-white" style="font-size: 1.8rem;"></i>
                </div>
                <div>
                    <h1 class="h3 mb-0 text-white">Cambiar Contraseña</h1>
                    <p class="text-white-50 mb-0">Actualiza tu contraseña de acceso</p>
                </div>
            </div>

            @* Mensajes de éxito/error *@
            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success border-0 d-flex align-items-center" role="alert">
                    <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                    <div>@Model.SuccessMessage</div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger border-0 d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                    <div>@Model.ErrorMessage</div>
                </div>
            }

            @* Formulario *@
            <div class="card bg-dark border-secondary">
                <div class="card-header bg-transparent border-secondary">
                    <h5 class="mb-0 text-white">
                        <i class="bi bi-shield-lock me-2 text-warning"></i>
                        Actualizar Contraseña
                    </h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="ChangePassword">
                        @Html.AntiForgeryToken()
                        
                        @* Contraseña actual *@
                        <div class="mb-4">
                            <label asp-for="CurrentPassword" class="form-label text-white">
                                <i class="bi bi-lock me-1"></i>
                                Contraseña Actual
                            </label>
                            <div class="input-group">
                                <input asp-for="CurrentPassword" 
                                       class="form-control bg-dark border-secondary text-white" 
                                       placeholder="Ingresa tu contraseña actual"
                                       id="currentPassword" />
                                <button class="btn btn-outline-secondary" type="button" 
                                        onclick="togglePassword('currentPassword')">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <hr class="border-secondary my-4">

                        @* Nueva contraseña *@
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label text-white">
                                <i class="bi bi-key me-1"></i>
                                Nueva Contraseña
                            </label>
                            <div class="input-group">
                                <input asp-for="NewPassword" 
                                       class="form-control bg-dark border-secondary text-white" 
                                       placeholder="Mínimo 8 caracteres"
                                       id="newPassword"
                                       oninput="checkPasswordStrength()" />
                                <button class="btn btn-outline-secondary" type="button" 
                                        onclick="togglePassword('newPassword')">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            @* Indicador de fortaleza *@
                            <div class="mt-2">
                                <div class="progress" style="height: 5px;">
                                    <div class="progress-bar" role="progressbar" id="strengthBar" 
                                         style="width: 0%"></div>
                                </div>
                                <small id="strengthText" class="text-white-50">Ingresa una contraseña</small>
                            </div>
                        </div>

                        @* Confirmar contraseña *@
                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label text-white">
                                <i class="bi bi-check2-square me-1"></i>
                                Confirmar Nueva Contraseña
                            </label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" 
                                       class="form-control bg-dark border-secondary text-white" 
                                       placeholder="Repite la nueva contraseña"
                                       id="confirmPassword"
                                       oninput="checkPasswordMatch()" />
                                <button class="btn btn-outline-secondary" type="button" 
                                        onclick="togglePassword('confirmPassword')">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            <small id="matchText" class="text-white-50"></small>
                        </div>

                        @* Requisitos de contraseña *@
                        <div class="alert border-0 mb-4" style="background: rgba(13, 202, 240, 0.1); border-left: 3px solid #0dcaf0 !important;">
                            <h6 class="text-info mb-2">
                                <i class="bi bi-info-circle me-1"></i>
                                Requisitos de la contraseña
                            </h6>
                            <ul class="mb-0 small text-white-50">
                                <li id="req-length" class="text-white-50">
                                    <i class="bi bi-circle me-1"></i>
                                    Mínimo 8 caracteres
                                </li>
                                <li id="req-upper" class="text-white-50">
                                    <i class="bi bi-circle me-1"></i>
                                    Al menos una mayúscula
                                </li>
                                <li id="req-lower" class="text-white-50">
                                    <i class="bi bi-circle me-1"></i>
                                    Al menos una minúscula
                                </li>
                                <li id="req-number" class="text-white-50">
                                    <i class="bi bi-circle me-1"></i>
                                    Al menos un número
                                </li>
                            </ul>
                        </div>

                        @* Botones *@
                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Profile", "Home")" class="btn btn-outline-secondary">
                                <i class="bi bi-x me-1"></i>
                                Cancelar
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-lg me-1"></i>
                                Cambiar Contraseña
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @* Información adicional *@
            <div class="card bg-dark border-secondary mt-4">
                <div class="card-body">
                    <h6 class="text-white mb-3">
                        <i class="bi bi-shield-check me-2 text-success"></i>
                        Consejos de seguridad
                    </h6>
                    <ul class="small text-white-50 mb-0">
                        <li>No uses la misma contraseña en múltiples sitios</li>
                        <li>Cambia tu contraseña periódicamente (cada 90 días recomendado)</li>
                        <li>No compartas tu contraseña con nadie</li>
                        <li>Usa un gestor de contraseñas para contraseñas seguras</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const btn = input.nextElementSibling;
            const icon = btn.querySelector('i');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }

        function checkPasswordStrength() {
            const password = document.getElementById('newPassword').value;
            const bar = document.getElementById('strengthBar');
            const text = document.getElementById('strengthText');
            
            let strength = 0;
            let checks = {
                length: password.length >= 8,
                upper: /[A-Z]/.test(password),
                lower: /[a-z]/.test(password),
                number: /[0-9]/.test(password),
                special: /[^A-Za-z0-9]/.test(password)
            };
            
            // Actualizar indicadores de requisitos
            updateRequirement('req-length', checks.length);
            updateRequirement('req-upper', checks.upper);
            updateRequirement('req-lower', checks.lower);
            updateRequirement('req-number', checks.number);
            
            // Calcular fortaleza
            if (checks.length) strength += 20;
            if (checks.upper) strength += 20;
            if (checks.lower) strength += 20;
            if (checks.number) strength += 20;
            if (checks.special) strength += 20;
            
            bar.style.width = strength + '%';
            
            if (strength < 40) {
                bar.className = 'progress-bar bg-danger';
                text.textContent = 'Débil';
                text.className = 'text-danger small';
            } else if (strength < 80) {
                bar.className = 'progress-bar bg-warning';
                text.textContent = 'Media';
                text.className = 'text-warning small';
            } else {
                bar.className = 'progress-bar bg-success';
                text.textContent = 'Fuerte';
                text.className = 'text-success small';
            }
            
            checkPasswordMatch();
        }
        
        function updateRequirement(elementId, met) {
            const el = document.getElementById(elementId);
            const icon = el.querySelector('i');
            
            if (met) {
                el.className = 'text-success';
                icon.className = 'bi bi-check-circle-fill me-1';
            } else {
                el.className = 'text-white-50';
                icon.className = 'bi bi-circle me-1';
            }
        }
        
        function checkPasswordMatch() {
            const newPass = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;
            const text = document.getElementById('matchText');
            
            if (confirmPass.length === 0) {
                text.textContent = '';
                text.className = 'text-white-50';
            } else if (newPass === confirmPass) {
                text.textContent = '✓ Las contraseñas coinciden';
                text.className = 'text-success small';
            } else {
                text.textContent = '✗ Las contraseñas no coinciden';
                text.className = 'text-danger small';
            }
        }
    </script>
}
