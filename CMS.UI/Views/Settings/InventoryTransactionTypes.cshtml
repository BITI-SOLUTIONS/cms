@* ================================================================================
   VISTA: CMS.UI/Views/Settings/InventoryTransactionTypes.cshtml
   PROPÓSITO: Mantenimiento del catálogo central de Tipos de Movimiento de Inventario
   TABLA:     admin.inventory_transaction_type  (BD central: cms)
   ================================================================================ *@
@{
    ViewData["Title"] = "Tipos de Movimiento de Inventario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    small, .form-text, small.text-muted, .text-muted small { color: #cbd5e1 !important; }
    .inv-type-badge { font-size: .75rem; font-weight: 600; padding: .25rem .55rem; border-radius: 5px; }
</style>

<div class="container-fluid py-3">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h4 class="text-white mb-0">
                <i class="bi bi-tags me-2 text-info"></i>Tipos de Movimiento de Inventario
            </h4>
            <small class="text-muted">Catálogo central compartido por todas las compañías</small>
        </div>
        <button class="btn btn-primary" onclick="ITT.openNew()">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Tipo
        </button>
    </div>

    <!-- Alert -->
    <div id="ittAlert" class="alert d-none mb-3" role="alert"></div>

    <!-- Tabla -->
    <div class="card bg-dark border-secondary">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover table-sm mb-0" id="tblTypes">
                    <thead>
                        <tr>
                            <th style="width:40px;">#</th>
                            <th>Código</th>
                            <th>Nombre</th>
                            <th>Icono / Emoji</th>
                            <th>Clase CSS Badge</th>
                            <th class="text-center">Tránsito</th>
                            <th class="text-center">En Inv.Mov.</th>
                            <th class="text-center">Orden</th>
                            <th class="text-center">Activo</th>
                            <th style="width:100px;"></th>
                        </tr>
                    </thead>
                    <tbody id="bodyTypes">
                        <tr>
                            <td colspan="10" class="text-center text-muted py-3">
                                <i class="bi bi-hourglass-split me-1"></i>Cargando…
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ============================================================
     MODAL CREAR / EDITAR
     ============================================================ -->
<div class="modal fade" id="ittModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary text-light">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="ittModalTitle">
                    <i class="bi bi-tag me-2 text-info"></i>Tipo de Movimiento
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="ittId">
                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label class="form-label">Código *
                            <small class="text-muted">(máx. 30 — sin espacios)</small>
                        </label>
                        <input type="text" id="ittCode" class="form-control" maxlength="30"
                               placeholder="Ej: CustomTransfer">
                        <small>Debe coincidir con el valor guardado en inventory_transaction.movement_type</small>
                    </div>
                    <div class="col-12 col-md-8">
                        <label class="form-label">Nombre *</label>
                        <input type="text" id="ittName" class="form-control" maxlength="100"
                               placeholder="Ej: Traslado Especial">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Descripción</label>
                        <textarea id="ittDesc" class="form-control" rows="2" maxlength="500"
                                  placeholder="Descripción del comportamiento de este tipo de movimiento"></textarea>
                    </div>
                    <div class="col-6 col-md-4">
                        <label class="form-label">Icono Bootstrap Icons</label>
                        <input type="text" id="ittIcon" class="form-control" maxlength="50"
                               placeholder="Ej: bi-truck">
                        <small>Clase de Bootstrap Icons</small>
                    </div>
                    <div class="col-6 col-md-2">
                        <label class="form-label">Emoji</label>
                        <input type="text" id="ittEmoji" class="form-control" maxlength="10"
                               placeholder="Ej: 🚛">
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Clase CSS Badge</label>
                        <input type="text" id="ittCss" class="form-control" maxlength="60"
                               placeholder="Ej: tp-TransitTransfer">
                        <small>Clase definida en el CSS del sistema para colorear el badge</small>
                    </div>
                    <div class="col-6 col-md-3">
                        <label class="form-label">Orden de aparición</label>
                        <input type="number" id="ittOrder" class="form-control" min="0" step="1" value="10">
                    </div>
                    <div class="col-6 col-md-3 d-flex align-items-end gap-3">
                        <div class="form-check form-switch mb-1">
                            <input class="form-check-input" type="checkbox" id="ittTransit">
                            <label class="form-check-label" for="ittTransit">Tránsito</label>
                            <div><small>Es TransitTransfer</small></div>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 d-flex align-items-end gap-4">
                        <div class="form-check form-switch mb-1">
                            <input class="form-check-input" type="checkbox" id="ittActive" checked>
                            <label class="form-check-label" for="ittActive">Activo</label>
                            <div><small>Disponible para usar</small></div>
                        </div>
                        <div class="form-check form-switch mb-1">
                            <input class="form-check-input" type="checkbox" id="ittShowInMovements" checked>
                            <label class="form-check-label" for="ittShowInMovements">Mostrar en Inventory Movements</label>
                            <div><small>Visible en dropdown de movimientos</small></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="ITT.save()">
                    <i class="bi bi-floppy me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal desactivar -->
<div class="modal fade" id="ittDeleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-danger text-light">
            <div class="modal-header border-danger">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Desactivar
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Desea desactivar el tipo <strong id="ittDeleteName"></strong>?</p>
                <small class="text-muted">
                    Los movimientos existentes que usan este tipo no se verán afectados.
                </small>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" onclick="ITT.confirmDelete()">
                    <i class="bi bi-trash me-1"></i>Desactivar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    window.ITT_API   = '@ViewBag.ApiBaseUrl';
    window.ITT_TOKEN = '@ViewBag.ApiToken';
</script>
<script src="~/js/inventoryTransactionTypes.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        ['ittModal', 'ittDeleteModal'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) document.body.appendChild(el);
        });
    });
</script>
}
